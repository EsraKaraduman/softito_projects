                    <a href="/Admin/Index" class="list-group-item list-group-item-action">Dashboard</a>
                    <a href="/Kategori/Index" class="list-group-item list-group-item-action">Kategoriler</a>
                    <a href="/Urun/Index" class="list-group-item list-group-item-action">Ürünler</a>
                    <a href="/Siparis/Index" class="list-group-item list-group-item-action">Siparişler</a>
                    <a href="/Kullanici/Index" class="list-group-item list-group-item-action">Kullanıcılar</a>
                </div>
            </div>

            <div class="col-9">
                @RenderBody()
            </div>
        </div>
    </div>

</body>
</html>
