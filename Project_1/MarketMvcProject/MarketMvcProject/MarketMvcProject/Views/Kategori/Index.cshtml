@model List<MarketMvcProject.Models.Kategori>
@{
    Layout = "_AdminLayout";
}

<h2>Kategoriler</h2>

<a href="/Kategori/Create" class="btn btn-primary mb-3">Yeni Kategori Ekle</a>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>ID</th>
            <th>Kategori Adı</th>
            <th>İşlemler</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var k in Model)
        {
            <tr>
                <td>@k.KategoriId</td>
                <td>@k.KategoriAdi</td>
                <td>
                    <a href="/Kategori/Edit/@k.KategoriId" class="btn btn-warning btn-sm">Düzenle</a>
                    <a href="/Kategori/Delete/@k.KategoriId" class="btn btn-danger btn-sm">Sil</a>
                </td>
            </tr>
        }
    </tbody>
</table>
