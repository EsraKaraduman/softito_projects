@model IEnumerable<SimakYolSupurge.Models.Request>
@{
    ViewData["Title"] = "Müşteri Talepleri";
}

<div class="page-header-simak">
    <div class="container">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center">
            <div>
                <h1 class="page-title mb-1">Müşteri Talepleri</h1>
                <p class="text-muted mb-0">Araç kiralama ve satın alma teklif taleplerinin yönetimi.</p>
            </div>
            <div class="mt-3 mt-md-0 d-flex gap-2">
                <a asp-action="ExportExcel" class="btn btn-outline-success d-flex align-items-center">
                    <i class="bi bi-file-earmark-excel me-2"></i> Excel İndir
                </a>
                <button onclick="exportPdf()" class="btn btn-outline-danger d-flex align-items-center">
                    <i class="bi bi-file-earmark-pdf me-2"></i> PDF İndir
                </button>
            </div>
        </div>
    </div>
</div>

<div class="container mb-5">
    <div class="row mb-4">
        <div class="col-md-6 mx-auto">
            <form asp-action="Index" method="get" class="d-flex gap-2">
                <div class="input-group shadow-sm rounded-3 overflow-hidden">
                    <span class="input-group-text bg-white border-end-0 text-muted"><i class="bi bi-search"></i></span>
                    <input type="text" name="search" value="@ViewBag.Search" class="form-control border-start-0 ps-0" placeholder="Müşteri adı, e-posta, telefon veya araç modeli ara..." />
                    <button type="submit" class="btn btn-success px-4">Ara</button>
                </div>
                @if (!string.IsNullOrEmpty(ViewBag.Search))
                {
                    <a asp-action="Index" class="btn btn-outline-secondary d-flex align-items-center">Temizle</a>
                }
            </form>
        </div>
    </div>

    <div class="table-simak-container" id="exportableContent">
        <div class="p-3 bg-light border-bottom border-light-subtle d-flex justify-content-between align-items-center">
            <span class="fw-bold text-dark"><i class="bi bi-envelope-paper me-2 text-success"></i> Gelen Talepler</span>
            <span class="badge bg-success-subtle text-success">Toplam @Model.Count() Talep</span>
        </div>
        <div class="table-responsive">
            <table class="table table-simak align-middle">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Müşteri Adı</th>
                        <th>İletişim</th>
                        <th>Talep Edilen Araç</th>
                        <th>Talep Türü</th>
                        <th>Talep Tarihi</th>
                        <th>Durum</th>
                        <th class="text-end">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="8" class="text-center py-5 text-muted">
                                <i class="bi bi-inbox d-block fs-1 mb-2"></i>
                                Henüz bir talep bulunmuyor.
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-bold">#@item.Id</td>
                                <td class="fw-semibold">@item.CustomerName</td>
                                <td>
                                    <div class="small"><i class="bi bi-envelope me-1 text-muted"></i> @item.CustomerEmail</div>
                                    <div class="small text-muted"><i class="bi bi-telephone me-1"></i> @item.CustomerPhone</div>
                                </td>
                                <td><i class="bi bi-truck me-1 text-success"></i> @item.VehicleModel</td>
                                <td>
                                    <span class="badge @(item.RequestType == "Kiralama" ? "bg-success-subtle text-success" : "bg-primary-subtle text-primary")">
                                        @item.RequestType
                                    </span>
                                </td>
                                <td>@item.RequestDate.ToString("dd.MM.yyyy")</td>
                                <td>
                                    <span class="badge rounded-pill px-2.5 py-1.5 @(item.Status == "Onaylandı" ? "bg-success text-white" : item.Status == "Reddedildi" ? "bg-danger text-white" : "bg-warning text-dark")">
                                        @item.Status
                                    </span>
                                </td>
                                <td class="text-end">
                                    <div class="btn-group">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-success"><i class="bi bi-pencil"></i></a>
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info"><i class="bi bi-eye"></i></a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
<script>
    function exportPdf() {
        const element = document.getElementById('exportableContent');
        const opt = {
            margin: 15,
            filename: 'Musteri_Talepleri_Listesi.pdf',
            image: { type: 'jpeg', quality: 0.98 },
            html2canvas: { scale: 2 },
            jsPDF: { unit: 'mm', format: 'a4', orientation: 'landscape' }
        };
        html2pdf().set(opt).from(element).save();
    }
</script>
