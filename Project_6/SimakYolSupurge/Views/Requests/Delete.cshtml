@model SimakYolSupurge.Models.Request
@{
    ViewData["Title"] = "Talebi Sil";
}

<div class="page-header-simak">
    <div class="container">
        <h1 class="page-title mb-1 text-danger">Talebi Sil</h1>
        <p class="text-muted mb-0">Bu müşteri talebini sistemden silmek istediğinize emin misiniz?</p>
    </div>
</div>

<div class="container mb-5">
    <div class="row">
        <div class="col-lg-6 mx-auto">
            <div class="form-card-simak border-danger">
                <div class="text-center mb-4">
                    <i class="bi bi-exclamation-triangle text-danger" style="font-size: 4rem;"></i>
                    <h3 class="fw-bold mt-2">Dikkat!</h3>
                    <p class="text-danger">Bu talep kaydı kalıcı olarak silinecektir. Bu işlem geri alınamaz.</p>
                </div>

                <div class="bg-light p-4 rounded-3 mb-4">
                    <div class="row mb-2">
                        <div class="col-4 fw-bold">Müşteri Adı:</div>
                        <div class="col-8">@Model.CustomerName</div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-4 fw-bold">Araç Modeli:</div>
                        <div class="col-8">@Model.VehicleModel</div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-4 fw-bold">Talep Türü:</div>
                        <div class="col-8">@Model.RequestType</div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-4 fw-bold">Talep Tarihi:</div>
                        <div class="col-8">@Model.RequestDate.ToString("dd.MM.yyyy")</div>
                    </div>
                    <div class="row">
                        <div class="col-4 fw-bold">Durum:</div>
                        <div class="col-8">@Model.Status</div>
                    </div>
                </div>

                <form asp-action="Delete" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    
                    <div class="d-flex gap-2 justify-content-center">
                        <button type="submit" class="btn btn-danger px-4 py-2">
                            <i class="bi bi-trash me-2"></i> Evet, Sil
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary px-4 py-2">Vazgeç</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
