@{
    ViewData["Title"] = "Yetkisiz Erişim";
}

<div class="auth-page">
    <div class="container text-center py-5">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="form-card-simak text-center">
                    <i class="bi bi-shield-slash text-danger" style="font-size: 5rem;"></i>
                    <h2 class="fw-bold text-danger mt-3">Yetkisiz Erişim</h2>
                    <p class="text-muted mt-2">Bu sayfayı görüntülemek için gerekli yetkiye sahip değilsiniz. Lütfen yönetici hesabı ile giriş yaptığınızdan emin olun.</p>
                    <div class="mt-4">
                        <a asp-controller="Home" asp-action="Index" class="btn btn-primary-simak px-4 me-2">Anasayfaya Dön</a>
                        <a asp-controller="Account" asp-action="Login" class="btn btn-outline-simak px-4">Giriş Ekranına Git</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
