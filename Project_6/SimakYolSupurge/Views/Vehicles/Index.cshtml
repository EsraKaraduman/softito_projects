@model IEnumerable<SimakYolSupurge.Models.Vehicle>
@{
    ViewData["Title"] = "Araçlar & İş Makinaları";
}

<div class="page-header-simak">
    <div class="container">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center">
            <div>
                <h1 class="page-title mb-1">Araçlar & İş Makinaları</h1>
                <p class="text-muted mb-0">Kiralık ve satılık yol süpürme araçları ile iş makinaları filomuz.</p>
            </div>
            <div class="mt-3 mt-md-0 d-flex gap-2">
                @if (User.IsInRole("Admin"))
                {
                    <a asp-action="Create" class="btn btn-primary-simak d-flex align-items-center">
                        <i class="bi bi-plus-circle me-2"></i> Yeni Araç Ekle
                    </a>
                }
                <a asp-action="ExportExcel" class="btn btn-outline-success d-flex align-items-center">
                    <i class="bi bi-file-earmark-excel me-2"></i> Excel İndir
                </a>
                <button onclick="exportPdf()" class="btn btn-outline-danger d-flex align-items-center">
                    <i class="bi bi-file-earmark-pdf me-2"></i> PDF İndir
                </button>
            </div>
        </div>
    </div>
</div>

<div class="container mb-5">
    <div class="row mb-4">
        <div class="col-md-8 mx-auto">
            <form asp-action="Index" method="get" class="d-flex gap-2">
                <div class="input-group shadow-sm rounded-3 overflow-hidden">
                    <span class="input-group-text bg-white border-end-0 text-muted"><i class="bi bi-search"></i></span>
                    <input type="text" name="search" value="@ViewBag.Search" class="form-control border-start-0 ps-0" placeholder="Marka, model, araç türü veya durumu ara..." />
                    <button type="submit" class="btn btn-success px-4">Ara</button>
                </div>
                @if (!string.IsNullOrEmpty(ViewBag.Search))
                {
                    <a asp-action="Index" class="btn btn-outline-secondary d-flex align-items-center">Temizle</a>
                }
            </form>
        </div>
    </div>

    <div id="exportableContent">
        <div class="row g-4">
            @if (!Model.Any())
            {
                <div class="col-12 text-center py-5">
                    <i class="bi bi-inbox text-muted" style="font-size: 4rem;"></i>
                    <h3 class="mt-3 text-muted">Aramanızla eşleşen araç bulunamadı.</h3>
                    <p class="text-muted">Lütfen farklı kelimelerle tekrar arayın.</p>
                </div>
            }
            else
            {
                @foreach (var item in Model)
                {
                    <div class="col-md-6 col-lg-4">
                        <div class="card card-simak h-100 shadow-sm border-light">
                            <div class="card-img-wrapper">
                                @if (string.IsNullOrEmpty(item.ImageUrl))
                                {
                                    <div class="w-100 h-100 d-flex align-items-center justify-content-center bg-light text-muted">
                                        <i class="bi bi-truck fs-1"></i>
                                    </div>
                                }
                                else
                                {
                                    <img src="@item.ImageUrl" alt="@item.Brand @item.Model" class="card-img" onerror="this.onerror=null; this.src='https://images.unsplash.com/photo-1605787020600-b9ebd5df1d07?q=80&w=800';">
                                }
                                <span class="badge badge-status @(item.Status == "Kiralık" ? "bg-success" : item.Status == "Satılık" ? "bg-primary" : "bg-warning text-dark")">
                                    @item.Status
                                </span>
                            </div>
                            <div class="card-body d-flex flex-column">
                                <span class="text-uppercase text-success fw-bold small tracking-wider">@item.Type</span>
                                <h4 class="card-title mt-1 mb-2">@item.Brand @item.Model</h4>
                                <p class="text-muted text-sm flex-grow-1">@(item.Description.Length > 100 ? item.Description.Substring(0, 97) + "..." : item.Description)</p>
                                
                                <div class="border-top pt-3 mt-3 d-flex justify-content-between align-items-center">
                                    <div>
                                        <span class="text-muted small d-block">Fiyat</span>
                                        <span class="card-price">@item.Price.ToString("N0") TL</span>
                                        @if (item.Status == "Kiralık")
                                        {
                                            <span class="text-muted small">/ Gün</span>
                                        }
                                    </div>
                                    <div class="d-flex gap-1">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-success px-3">Detay</a>
                                        @if (User.Identity?.IsAuthenticated == true && !User.IsInRole("Admin"))
                                        {
                                            <a asp-controller="Requests" asp-action="Create" asp-route-vehicleModel="@(item.Brand + " " + item.Model)" class="btn btn-sm btn-success px-3">Teklif Al</a>
                                        }
                                        @if (User.IsInRole("Admin"))
                                        {
                                            <div class="btn-group">
                                                <button type="button" class="btn btn-sm btn-success dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
                                                    İşlem
                                                </button>
                                                <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                                                    <li><a class="dropdown-item" asp-action="Edit" asp-route-id="@item.Id"><i class="bi bi-pencil me-2"></i> Düzenle</a></li>
                                                    <li><a class="dropdown-item text-danger" asp-action="Delete" asp-route-id="@item.Id"><i class="bi bi-trash me-2"></i> Sil</a></li>
                                                </ul>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
<script>
    function exportPdf() {
        const element = document.getElementById('exportableContent');
        const opt = {
            margin: 15,
            filename: 'Simak_Araclar_Listesi.pdf',
            image: { type: 'jpeg', quality: 0.98 },
            html2canvas: { scale: 2, useCORS: true },
            jsPDF: { unit: 'mm', format: 'a4', orientation: 'portrait' }
        };
        html2pdf().set(opt).from(element).save();
    }
</script>
