@model IEnumerable<SimakYolSupurge.Models.Maintenance>
@{
    ViewData["Title"] = "Bakım & Onarım Takibi";
}

<div class="page-header-simak">
    <div class="container">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center">
            <div>
                <h1 class="page-title mb-1">Bakım & Onarım Takibi</h1>
                <p class="text-muted mb-0">İş makinaları ve süpürme araçlarının servis, periyodik bakım ve onarım geçmişi.</p>
            </div>
            <div class="mt-3 mt-md-0 d-flex gap-2">
                @if (User.IsInRole("Admin"))
                {
                    <a asp-action="Create" class="btn btn-primary-simak d-flex align-items-center">
                        <i class="bi bi-plus-circle me-2"></i> Yeni Bakım Ekle
                    </a>
                }
                <a asp-action="ExportExcel" class="btn btn-outline-success d-flex align-items-center">
                    <i class="bi bi-file-earmark-excel me-2"></i> Excel İndir
                </a>
                <button onclick="exportPdf()" class="btn btn-outline-danger d-flex align-items-center">
                    <i class="bi bi-file-earmark-pdf me-2"></i> PDF İndir
                </button>
            </div>
        </div>
    </div>
</div>

<div class="container mb-5">
    <div class="row mb-4">
        <div class="col-md-6 mx-auto">
            <form asp-action="Index" method="get" class="d-flex gap-2">
                <div class="input-group shadow-sm rounded-3 overflow-hidden">
                    <span class="input-group-text bg-white border-end-0 text-muted"><i class="bi bi-search"></i></span>
                    <input type="text" name="search" value="@ViewBag.Search" class="form-control border-start-0 ps-0" placeholder="Araç modeli, usta veya durum ara..." />
                    <button type="submit" class="btn btn-success px-4">Ara</button>
                </div>
                @if (!string.IsNullOrEmpty(ViewBag.Search))
                {
                    <a asp-action="Index" class="btn btn-outline-secondary d-flex align-items-center">Temizle</a>
                }
            </form>
        </div>
    </div>

    <div class="table-simak-container" id="exportableContent">
        <div class="p-3 bg-light border-bottom border-light-subtle d-flex justify-content-between align-items-center">
            <span class="fw-bold text-dark"><i class="bi bi-list-task me-2 text-success"></i> Servis Kayıtları</span>
            <span class="badge bg-success-subtle text-success">Toplam @Model.Count() Kayıt</span>
        </div>
        <div class="table-responsive">
            <table class="table table-simak align-middle">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Araç Modeli</th>
                        <th>Açıklama</th>
                        <th>Giriş Tarihi</th>
                        <th>Çıkış Tarihi</th>
                        <th>Maliyet</th>
                        <th>Durum</th>
                        <th>Teknisyen / Servis</th>
                        @if (User.IsInRole("Admin"))
                        {
                            <th class="text-end">İşlemler</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="9" class="text-center py-5 text-muted">
                                <i class="bi bi-tools d-block fs-1 mb-2"></i>
                                Kayıt bulunamadı.
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-bold">#@item.Id</td>
                                <td><i class="bi bi-truck me-2 text-success"></i> @item.VehicleModel</td>
                                <td><span class="text-truncate d-inline-block" style="max-width: 250px;" title="@item.Description">@item.Description</span></td>
                                <td>@item.StartDate.ToString("dd.MM.yyyy")</td>
                                <td>@(item.EndDate?.ToString("dd.MM.yyyy") ?? "Devam Ediyor")</td>
                                <td class="fw-semibold text-success">@item.Cost.ToString("N0") TL</td>
                                <td>
                                    <span class="badge rounded-pill px-2.5 py-1.5 @(item.Status == "Tamamlandı" ? "bg-success-subtle text-success border border-success-subtle" : item.Status == "Devam Ediyor" ? "bg-warning-subtle text-warning-emphasis border border-warning-subtle" : "bg-info-subtle text-info border border-info-subtle")">
                                        @item.Status
                                    </span>
                                </td>
                                <td><i class="bi bi-person me-1 text-muted"></i> @item.TechnicianName</td>
                                @if (User.IsInRole("Admin"))
                                {
                                    <td class="text-end">
                                        <div class="btn-group">
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-success"><i class="bi bi-pencil"></i></a>
                                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info"><i class="bi bi-eye"></i></a>
                                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></a>
                                        </div>
                                    </td>
                                }
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
<script>
    function exportPdf() {
        const element = document.getElementById('exportableContent');
        const opt = {
            margin: 15,
            filename: 'Bakim_Onarim_Listesi.pdf',
            image: { type: 'jpeg', quality: 0.98 },
            html2canvas: { scale: 2 },
            jsPDF: { unit: 'mm', format: 'a4', orientation: 'landscape' }
        };
        html2pdf().set(opt).from(element).save();
    }
</script>
