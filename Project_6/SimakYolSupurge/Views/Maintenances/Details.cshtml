@model SimakYolSupurge.Models.Maintenance
@{
    ViewData["Title"] = "Bakım Detayları";
}

<div class="page-header-simak">
    <div class="container">
        <h1 class="page-title mb-1">Bakım & Servis Kartı Detayı</h1>
        <p class="text-muted mb-0">Seçilen bakım ve onarım işlemine ait detaylı servis kartı bilgisi.</p>
    </div>
</div>

<div class="container mb-5">
    <div class="row">
        <div class="col-lg-8 mx-auto">
            <div class="form-card-simak">
                <div class="d-flex justify-content-between align-items-start border-bottom pb-3 mb-4">
                    <div>
                        <span class="text-muted small">Bakım Kartı #@Model.Id</span>
                        <h2 class="fw-bold text-success mt-1">@Model.VehicleModel</h2>
                    </div>
                    <span class="badge px-3 py-2 fs-6 rounded-pill @(Model.Status == "Tamamlandı" ? "bg-success" : Model.Status == "Devam Ediyor" ? "bg-warning text-dark" : "bg-info")">
                        @Model.Status
                    </span>
                </div>

                <div class="mb-4">
                    <h5 class="fw-bold text-dark"><i class="bi bi-file-earmark-text me-2 text-success"></i> Yapılan İşlemler / Arıza Detayı</h5>
                    <p class="text-muted bg-light p-3 rounded-3 mt-2" style="white-space: pre-line;">@Model.Description</p>
                </div>

                <div class="row g-4 mb-4">
                    <div class="col-md-6">
                        <div class="p-3 border rounded-3 h-100">
                            <span class="text-muted d-block small mb-1">Tarih Bilgileri</span>
                            <div class="d-flex justify-content-between mb-1">
                                <span>Giriş Tarihi:</span>
                                <span class="fw-semibold">@Model.StartDate.ToString("dd.MM.yyyy")</span>
                            </div>
                            <div class="d-flex justify-content-between">
                                <span>Çıkış Tarihi:</span>
                                <span class="fw-semibold">@(Model.EndDate?.ToString("dd.MM.yyyy") ?? "Devam Ediyor")</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="p-3 border rounded-3 h-100">
                            <span class="text-muted d-block small mb-1">Finansal & Teknik</span>
                            <div class="d-flex justify-content-between mb-1">
                                <span>Bakım Maliyeti:</span>
                                <span class="fw-bold text-success">@Model.Cost.ToString("N0") TL</span>
                            </div>
                            <div class="d-flex justify-content-between">
                                <span>Usta / Teknisyen:</span>
                                <span class="fw-semibold">@Model.TechnicianName</span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary-simak px-4">
                            <i class="bi bi-pencil me-2"></i> Düzenle
                        </a>
                        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger px-4">
                            <i class="bi bi-trash me-2"></i> Sil
                        </a>
                    }
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">Listeye Dön</a>
                </div>
            </div>
        </div>
    </div>
</div>
