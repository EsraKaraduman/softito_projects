@{
    ViewData["Title"] = "Anasayfa - Yol Süpürme & İş Makinaları";
}

<section class="hero-section d-flex align-items-center">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 mb-5 mb-lg-0">
                <span class="badge bg-success-subtle text-success border border-success-subtle px-3 py-2 rounded-pill font-weight-bold mb-3">Güvenilir Temizlik & Güçlü Makinalar</span>
                <h1 class="hero-title">Yol Süpürme ve İş Makinalarında Çözüm Ortağınız</h1>
                <p class="hero-subtitle mb-4">Belediyeler, endüstriyel tesisler ve şantiyeler için profesyonel yol süpürme araçları ve iş makinaları kiralama, satın alma ve yetkili bakım onarım hizmetleri.</p>
                <div class="d-flex gap-3">
                    <a asp-controller="Vehicles" asp-action="Index" class="btn btn-primary-simak btn-lg px-4">
                        <i class="bi bi-truck me-2"></i> Araçlarımızı İnceleyin
                    </a>
                    <a asp-controller="Requests" asp-action="Create" class="btn btn-outline-simak btn-lg px-4">
                        <i class="bi bi-chat-left-dots me-2"></i> Teklif İsteyin
                    </a>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="hero-image-wrapper">
                    <img src="/images/hero_sweeper.jpg" alt="Yol Süpürme Aracı" class="img-fluid rounded-4 shadow">
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5 bg-white">
    <div class="container my-5">
        <div class="text-center mb-5">
            <h2 class="fw-bold text-success mb-2">Hizmetlerimiz</h2>
            <p class="text-muted mx-auto" style="max-width: 600px;">Simak Yol Süpürge olarak temiz bir çevre ve güçlü altyapı projeleri için profesyonel çözümler sunuyoruz.</p>
        </div>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="feature-box text-center">
                    <div class="feature-icon-wrapper mx-auto">
                        <i class="bi bi-calendar-check"></i>
                    </div>
                    <h4 class="fw-bold mb-3">Araç Kiralama</h4>
                    <p class="text-muted">Projenizin süresine göre esnek günlük, haftalık veya aylık kiralama seçenekleriyle maliyetlerinizi optimize edin.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-box text-center">
                    <div class="feature-icon-wrapper mx-auto">
                        <i class="bi bi-cart3"></i>
                    </div>
                    <h4 class="fw-bold mb-3">Araç Satış</h4>
                    <p class="text-muted">Dünya markası yol süpürme araçlarını ve iş makinalarını en uygun finansal koşullarla filonuza katın.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-box text-center">
                    <div class="feature-icon-wrapper mx-auto">
                        <i class="bi bi-tools"></i>
                    </div>
                    <h4 class="fw-bold mb-3">Bakım & Onarım</h4>
                    <p class="text-muted">Alanında uzman teknik ekibimizle periyodik bakım, parça değişimi ve arıza onarım işlemlerinizi hızla tamamlayalım.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5 bg-light">
    <div class="container my-4">
        <div class="row align-items-center g-5">
            <div class="col-lg-5">
                <img src="https://images.unsplash.com/photo-1541899481282-d53bffe3c35d?q=80&w=800" alt="Yol Süpürme Araç Filosu" class="img-fluid rounded-4 shadow">
            </div>
            <div class="col-lg-7">
                <h2 class="fw-bold text-success mb-4">Geniş ve Modern Araç Filosu</h2>
                <p class="text-muted mb-4">Dar sokaklara uygun kompakt süpürme araçlarından, otoyol ve endüstriyel tesisler için geliştirilmiş büyük vakumlu süpürme kamyonlarına kadar zengin bir yelpazeye sahibiz. Tüm araçlarımız düzenli bakımlardan geçirilerek yüksek verimlilik ve düşük yakıt tüketimi garanti eder.</p>
                <div class="row g-3">
                    <div class="col-md-6 d-flex align-items-center">
                        <i class="bi bi-check-circle-fill text-success fs-5 me-2"></i>
                        <span class="fw-semibold">Vakumlu Süpürme Kamyonları</span>
                    </div>
                    <div class="col-md-6 d-flex align-items-center">
                        <i class="bi bi-check-circle-fill text-success fs-5 me-2"></i>
                        <span class="fw-semibold">Kompakt Kaldırım Süpürgeleri</span>
                    </div>
                    <div class="col-md-6 d-flex align-items-center">
                        <i class="bi bi-check-circle-fill text-success fs-5 me-2"></i>
                        <span class="fw-semibold">Endüstriyel Süpürme Makinaları</span>
                    </div>
                    <div class="col-md-6 d-flex align-items-center">
                        <i class="bi bi-check-circle-fill text-success fs-5 me-2"></i>
                        <span class="fw-semibold">Yükleyici & Ekskavatörler</span>
                    </div>
                </div>
                <div class="mt-4">
                    <a asp-controller="Vehicles" asp-action="Index" class="btn btn-primary-simak px-4 py-2 mt-2">
                        Filoyu Keşfet <i class="bi bi-arrow-right ms-2"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5 bg-success text-white">
    <div class="container py-4 text-center">
        <h2 class="fw-bold mb-3">İhtiyacınıza En Uygun Çözümü Birlikte Belirleyelim</h2>
        <p class="lead mb-4" style="opacity: 0.9;">Hemen üye olun, kiralama veya satın alma talebinizi iletin, uzman ekibimiz en kısa sürede size özel teklifle dönüş yapsın.</p>
        @if (User.Identity?.IsAuthenticated == true)
        {
            <a asp-controller="Requests" asp-action="Create" class="btn btn-light btn-lg text-success fw-bold px-5">
                <i class="bi bi-file-earmark-text me-2"></i> Talep Oluştur
            </a>
        }
        else
        {
            <div class="d-flex justify-content-center gap-3">
                <a asp-controller="Account" asp-action="Register" class="btn btn-light btn-lg text-success fw-bold px-4">Kayıt Ol</a>
                <a asp-controller="Account" asp-action="Login" class="btn btn-outline-light btn-lg px-4">Giriş Yap</a>
            </div>
        }
    </div>
</section>
