@page
@model Dukkanrzrpg.Pages.LoginModel
@{
    ViewData["Title"] = "Giriş Yap";
}

<div class="login-container">
    <div class="form-toy text-center">
        <h2 class="mb-4" style="color: #ff758f; font-weight: 700;">ToyLand Giriş 🧸</h2>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger" role="alert">
                @Model.ErrorMessage
            </div>
        }

        <form method="post">
            <div class="mb-3 text-start">
                <label class="form-label" style="font-weight: 600;">Kullanıcı Adı</label>
                <input type="text" class="form-control form-toy-control" asp-for="Username" placeholder="Kullanıcı adınızı girin" required />
            </div>

            <div class="mb-4 text-start">
                <label class="form-label" style="font-weight: 600;">Şifre</label>
                <input type="password" class="form-control form-toy-control" asp-for="Password" placeholder="Şifrenizi girin" required />
            </div>

            <button type="submit" class="btn btn-toy-primary w-100 py-3">Giriş Yap 🔑</button>
        </form>

        <div class="mt-3 text-muted" style="font-size: 0.9rem;">
            Test Hesapları:<br />
            admin / 123 (Esra Admin)<br />
            user / 123 (Canan Personel)
        </div>
    </div>
</div>
