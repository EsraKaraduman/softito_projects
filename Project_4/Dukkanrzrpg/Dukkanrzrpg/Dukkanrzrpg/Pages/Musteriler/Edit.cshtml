@page
@model Dukkanrzrpg.Pages.Musteriler.EditModel
@{
    ViewData["Title"] = "Müşteri Düzenle";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="form-toy">
            <h2 class="mb-4 text-center" style="color: #ff758f; font-weight: 700;">📝 Müşteri Düzenle</h2>

            @if (!string.IsNullOrEmpty(Model.errorMessage))
            {
                <div class="alert alert-danger" role="alert">
                    @Model.errorMessage
                </div>
            }

            <form method="post">
                <input type="hidden" name="ID" value="@Model.Musteribilgi.ID" />

                <div class="mb-3">
                    <label class="form-label" style="font-weight: 600;">Ad Soyad *</label>
                    <input type="text" class="form-control form-toy-control" name="AdSoyad" value="@Model.Musteribilgi.AdSoyad" required />
                </div>

                <div class="mb-3">
                    <label class="form-label" style="font-weight: 600;">E-posta *</label>
                    <input type="email" class="form-control form-toy-control" name="Email" value="@Model.Musteribilgi.Email" required />
                </div>

                <div class="mb-3">
                    <label class="form-label" style="font-weight: 600;">Telefon *</label>
                    <input type="tel" class="form-control form-toy-control" name="Telefon" value="@Model.Musteribilgi.Telefon" required />
                </div>

                <div class="mb-4">
                    <label class="form-label" style="font-weight: 600;">Adres *</label>
                    <textarea class="form-control form-toy-control" name="Adres" rows="3" required>@Model.Musteribilgi.Adres</textarea>
                </div>

                <div class="d-flex justify-content-between">
                    <a class="btn btn-toy-secondary py-2 px-4" href="/Musteriler/Index">❌ İptal</a>
                    <button type="submit" class="btn btn-toy-primary py-2 px-4">💾 Güncelle</button>
                </div>
            </form>
        </div>
    </div>
</div>
