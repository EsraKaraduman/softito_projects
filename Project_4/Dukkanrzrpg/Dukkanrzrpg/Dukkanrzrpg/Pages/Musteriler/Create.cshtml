@page
@model Dukkanrzrpg.Pages.Musteriler.CreateModel
@{
    ViewData["Title"] = "Yeni Müşteri Ekle";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="form-toy">
            <h2 class="mb-4 text-center" style="color: #ff758f; font-weight: 700;">👥 Yeni Müşteri Ekle</h2>

            @if (!string.IsNullOrEmpty(Model.errorMessage))
            {
                <div class="alert alert-danger" role="alert">
                    @Model.errorMessage
                </div>
            }

            <form method="post">
                <div class="mb-3">
                    <label class="form-label" style="font-weight: 600;">Ad Soyad *</label>
                    <input type="text" class="form-control form-toy-control" name="AdSoyad" value="@Model.Musteribilgi.AdSoyad" placeholder="Müşteri adını ve soyadını girin" required />
                </div>

                <div class="mb-3">
                    <label class="form-label" style="font-weight: 600;">E-posta *</label>
                    <input type="email" class="form-control form-toy-control" name="Email" value="@Model.Musteribilgi.Email" placeholder="ornek@mail.com" required />
                </div>

                <div class="mb-3">
                    <label class="form-label" style="font-weight: 600;">Telefon *</label>
                    <input type="tel" class="form-control form-toy-control" name="Telefon" value="@Model.Musteribilgi.Telefon" placeholder="05551112233" required />
                </div>

                <div class="mb-3">
                    <label class="form-label" style="font-weight: 600;">Giriş Tarihi *</label>
                    <input type="date" class="form-control form-toy-control" name="Giris" value="@(string.IsNullOrEmpty(Model.Musteribilgi.Giris) ? DateTime.Now.ToString("yyyy-MM-dd") : Model.Musteribilgi.Giris)" required />
                </div>

                <div class="mb-4">
                    <label class="form-label" style="font-weight: 600;">Adres *</label>
                    <textarea class="form-control form-toy-control" name="Adres" rows="3" placeholder="Müşteri adresi..." required>@Model.Musteribilgi.Adres</textarea>
                </div>

                <div class="d-flex justify-content-between">
                    <a class="btn btn-toy-secondary py-2 px-4" href="/Musteriler/Index">❌ İptal</a>
                    <button type="submit" class="btn btn-toy-primary py-2 px-4">💾 Kaydet</button>
                </div>
            </form>
        </div>
    </div>
</div>