@page
@model Dukkanrzrpg.Pages.Musteriler.IndexModel
@{
    ViewData["Title"] = "Müşteriler";
}

<div class="row align-items-center mb-4 no-print">
    <div class="col-md-6">
        <h2 style="color: #ff758f; font-weight: 700;">👥 Müşteri Listesi</h2>
    </div>
    <div class="col-md-6 text-md-end">
        <a class="btn btn-toy-primary" href="/Musteriler/Create">➕ Yeni Müşteri Ekle</a>
    </div>
</div>

<form method="get" class="mb-4 no-print">
    <div class="row g-3">
        <div class="col-md-9">
            <input type="text" class="form-control form-toy-control" name="SearchTerm" value="@Model.SearchTerm" placeholder="Müşteri adı, e-posta veya telefon ile ara..." />
        </div>
        <div class="col-md-3">
            <button type="submit" class="btn btn-toy-primary w-100 py-2">🔍 Ara</button>
        </div>
    </div>
</form>

<div class="table-responsive">
    <table class="table toy-table">
        <thead>
            <tr>
                <th>Müşteri No</th>
                <th>Ad Soyad</th>
                <th>E-posta</th>
                <th>Telefon</th>
                <th>Adres</th>
                <th>Kayıt Tarihi</th>
                <th class="no-print">İşlem</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.listele)
            {
                <tr>
                    <td style="font-weight: 700; color: #ff758f;">@item.ID</td>
                    <td style="font-weight: 600;">@item.AdSoyad</td>
                    <td>@item.Email</td>
                    <td>@item.Telefon</td>
                    <td>@item.Adres</td>
                    <td>@item.Giris</td>
                    <td class="no-print">
                        <a class="btn btn-sm btn-outline-warning rounded-pill me-1 px-3" href="/Musteriler/Edit?id=@item.ID">Düzenle</a>
                        <a class="btn btn-sm btn-outline-danger rounded-pill px-3" href="/Musteriler/Delete?id=@item.ID">Sil</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>