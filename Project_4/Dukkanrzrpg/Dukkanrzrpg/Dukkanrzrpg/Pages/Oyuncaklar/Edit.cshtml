@page
@model Dukkanrzrpg.Pages.Oyuncaklar.EditModel
@{
    ViewData["Title"] = "Oyuncak Düzenle";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="form-toy">
            <h2 class="mb-4 text-center" style="color: #ff758f; font-weight: 700;">📝 Oyuncak Düzenle</h2>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger" role="alert">
                    @Model.ErrorMessage
                </div>
            }

            <form method="post">
                <input type="hidden" asp-for="OyuncakBilgi.ID" />

                <div class="mb-3">
                    <label class="form-label" style="font-weight: 600;">Oyuncak Adı *</label>
                    <input type="text" class="form-control form-toy-control" asp-for="OyuncakBilgi.Ad" required />
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label" style="font-weight: 600;">Kategori</label>
                        <input type="text" class="form-control form-toy-control" asp-for="OyuncakBilgi.Kategori" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label" style="font-weight: 600;">Yaş Grubu</label>
                        <input type="text" class="form-control form-toy-control" asp-for="OyuncakBilgi.YasGrubu" />
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label" style="font-weight: 600;">Fiyat (TL) *</label>
                        <input type="number" step="0.01" class="form-control form-toy-control" asp-for="OyuncakBilgi.Fiyat" required />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label" style="font-weight: 600;">Stok (Adet) *</label>
                        <input type="number" class="form-control form-toy-control" asp-for="OyuncakBilgi.Stok" required />
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label" style="font-weight: 600;">Görsel URL</label>
                    <input type="url" class="form-control form-toy-control" asp-for="OyuncakBilgi.ResimUrl" />
                </div>

                <div class="mb-4">
                    <label class="form-label" style="font-weight: 600;">Açıklama</label>
                    <textarea class="form-control form-toy-control" asp-for="OyuncakBilgi.Aciklama" rows="3"></textarea>
                </div>

                <div class="d-flex justify-content-between">
                    <a class="btn btn-toy-secondary py-2 px-4" href="/Oyuncaklar/Index">❌ İptal</a>
                    <button type="submit" class="btn btn-toy-primary py-2 px-4">💾 Güncelle</button>
                </div>
            </form>
        </div>
    </div>
</div>
