@page
@model Dukkanrzrpg.Pages.RaporModel
@{
    ViewData["Title"] = "Dükkan Raporları";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 style="color: #ff758f; font-weight: 700;">📊 Dükkan İstatistik Raporu</h2>
    <button class="btn btn-toy-primary no-print" onclick="window.print()">🖨️ PDF Rapor Al (Yazdır)</button>
</div>

<div class="row g-4 mb-5 print-container">
    <div class="col-md-3 col-sm-6">
        <div class="report-card">
            <div class="report-icon">🧸</div>
            <div class="report-val">@Model.ToplamOyuncak</div>
            <div class="text-muted font-weight-bold">Toplam Oyuncak Tipi</div>
        </div>
    </div>
    <div class="col-md-3 col-sm-6">
        <div class="report-card">
            <div class="report-icon">👥</div>
            <div class="report-val">@Model.ToplamMusteri</div>
            <div class="text-muted font-weight-bold">Kayıtlı Müşteri</div>
        </div>
    </div>
    <div class="col-md-3 col-sm-6">
        <div class="report-card" style="border-color: #ff6b6b;">
            <div class="report-icon" style="filter: grayscale(0);">⚠️</div>
            <div class="report-val" style="color: #ff6b6b;">@Model.KritikStokSayisi</div>
            <div class="text-muted font-weight-bold">Kritik Stok (< 10)</div>
        </div>
    </div>
    <div class="col-md-3 col-sm-6">
        <div class="report-card" style="border-color: #4ea8de;">
            <div class="report-icon">💰</div>
            <div class="report-val" style="color: #4ea8de;">@Model.ToplamStokDegeri.ToString("C2")</div>
            <div class="text-muted font-weight-bold">Toplam Envanter Değeri</div>
        </div>
    </div>
</div>

<div class="form-toy">
    <h4 class="mb-4" style="color: #ff758f; font-weight: 700;">📂 Kategori Bazında Envanter Dağılımı</h4>
    <div class="table-responsive">
        <table class="table toy-table mb-0">
            <thead>
                <tr>
                    <th>Kategori Adı</th>
                    <th>Oyuncak Tipi Sayısı</th>
                    <th>Toplam Fiziksel Stok (Adet)</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var rapor in Model.KategoriRaporListesi)
                {
                    <tr>
                        <td style="font-weight: 600; color: #4a4e69;">@rapor.KategoriAdi</td>
                        <td style="font-weight: 700; color: #ff758f;">@rapor.OyuncakSayisi</td>
                        <td style="font-weight: 700; color: #4ea8de;">@rapor.ToplamStok Adet</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
