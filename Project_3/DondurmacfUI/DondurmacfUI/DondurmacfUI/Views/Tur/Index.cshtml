@model IEnumerable<Dondurmacf.Model.DondurmaTur>

@{
    ViewData["Title"] = "Dondurma Türleri";
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
    <h1 class="page-title mb-0">Dondurma Türleri</h1>

    <form asp-action="Index" method="get" class="d-flex align-items-center gap-2">
        <input type="text" name="searchString" value="@ViewBag.CurrentFilter" class="form-control form-control-custom" placeholder="Tür veya Ürün adı ara..." style="width: 250px;" autocomplete="off" />
        <button type="submit" class="btn btn-primary-custom">🔍 Ara</button>
        @if (!string.IsNullOrEmpty(ViewBag.CurrentFilter))
        {
            <a asp-action="Index" class="btn btn-secondary-custom">Temizle</a>
        }
    </form>

    <a asp-action="Create" class="btn btn-primary-custom">✨ Yeni Tür Ekle</a>
</div>

<div class="card card-custom p-4 border-0">
    <div class="table-responsive">
        <table class="table table-custom">
            <thead>
                <tr>
                    <th>Tür No</th>
                    <th>Dondurma Türü (Adı)</th>
                    <th>Ürün Grubu</th>
                    <th>Fiyat</th>
                    <th>Ekleyen Kullanıcı</th>
                    <th class="text-end">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.TurNo</td>
                        <td class="font-weight-semibold text-dark">@item.Tur</td>
                        <td>
                            <span class="badge-custom-secondary">@item.Urun?.UrunAdi</span>
                        </td>
                        <td class="text-success font-weight-bold">@item.Fiyat ₺</td>
                        <td>
                            <span class="text-muted">👤 @(item.EkleyenKullanici?.AdSoyad ?? "Bilinmiyor")</span>
                        </td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@item.TurNo" class="btn btn-sm btn-secondary-custom me-2">Düzenle</a>
                            <a asp-action="Delete" asp-route-id="@item.TurNo" class="btn btn-sm btn-danger rounded-pill px-3">Sil</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
