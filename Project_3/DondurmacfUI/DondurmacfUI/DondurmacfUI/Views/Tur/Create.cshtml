@model Dondurmacf.Model.DondurmaTur

@{
    ViewData["Title"] = "Dondurma Türü Ekle";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <h1 class="page-title mb-4">Yeni Dondurma Türü Ekle</h1>
        <div class="card card-custom p-4 border-0">
            <div class="card-body">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Tur" class="form-label font-weight-semibold">Tür Adı (Örn: Çikolatalı)</label>
                        <input asp-for="Tur" class="form-control form-control-custom" placeholder="Dondurma türü adını girin" required autocomplete="off" />
                        <span asp-validation-for="Tur" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Fiyat" class="form-label font-weight-semibold">Fiyat (₺)</label>
                        <input asp-for="Fiyat" type="number" class="form-control form-control-custom" placeholder="Fiyat girin" required />
                        <span asp-validation-for="Fiyat" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="UrunNo" class="form-label font-weight-semibold">Ürün Kategorisi</label>
                        <select asp-for="UrunNo" class="form-control form-control-custom" asp-items="ViewBag.UrunNo">
                            <option value="">-- Kategori Seçin --</option>
                        </select>
                        <span asp-validation-for="UrunNo" class="text-danger small"></span>
                    </div>

                    <div class="d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-secondary-custom">Geri Dön</a>
                        <button type="submit" class="btn btn-primary-custom">Kaydet</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
