@model Dondurmacf.Model.DondurmaTur

@{
    ViewData["Title"] = "Dondurma Türü Düzenle";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <h1 class="page-title mb-4">Dondurma Türünü Düzenle</h1>
        <div class="card card-custom p-4 border-0">
            <div class="card-body">
                <form asp-action="Edit" asp-route-id="@Model.TurNo" method="post">
                    <input type="hidden" asp-for="TurNo" />
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Tur" class="form-label font-weight-semibold">Tür Adı</label>
                        <input asp-for="Tur" class="form-control form-control-custom" required autocomplete="off" />
                        <span asp-validation-for="Tur" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Fiyat" class="form-label font-weight-semibold">Fiyat (₺)</label>
                        <input asp-for="Fiyat" type="number" class="form-control form-control-custom" required />
                        <span asp-validation-for="Fiyat" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="UrunNo" class="form-label font-weight-semibold">Ürün Kategorisi</label>
                        <select asp-for="UrunNo" class="form-control form-control-custom" asp-items="ViewBag.UrunNo"></select>
                        <span asp-validation-for="UrunNo" class="text-danger small"></span>
                    </div>

                    <div class="d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-secondary-custom">Geri Dön</a>
                        <button type="submit" class="btn btn-primary-custom">Güncelle</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
