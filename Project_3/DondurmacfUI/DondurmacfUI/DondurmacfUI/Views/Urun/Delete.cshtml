@model Dondurmacf.Model.Urun

@{
    ViewData["Title"] = "Ürün Sil";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <h1 class="page-title text-danger mb-4">Ürünü Sil</h1>
        <div class="card card-custom p-4 border-0">
            <div class="card-body">
                <h4 class="text-dark font-weight-semibold mb-3">Bu ürünü silmek istediğinize emin misiniz?</h4>
                <p class="text-muted">Bu işlem geri alınamaz ve bu kategori altındaki tüm verileri etkileyebilir.</p>
                <hr class="my-4" />
                <dl class="row">
                    <dt class="col-sm-3 font-weight-bold text-dark">Ürün No</dt>
                    <dd class="col-sm-9">@Model.UrunNo</dd>

                    <dt class="col-sm-3 font-weight-bold text-dark">Ürün Adı</dt>
                    <dd class="col-sm-9">@Model.UrunAdi</dd>

                    <dt class="col-sm-3 font-weight-bold text-dark">Açıklama</dt>
                    <dd class="col-sm-9">@Model.Aciklama</dd>
                </dl>

                <form asp-action="Delete" asp-route-id="@Model.UrunNo" class="mt-4">
                    <input type="hidden" asp-for="UrunNo" />
                    <div class="d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-secondary-custom">Geri Dön</a>
                        <button type="submit" class="btn btn-danger rounded-pill px-4 py-2">Evet, Sil</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
