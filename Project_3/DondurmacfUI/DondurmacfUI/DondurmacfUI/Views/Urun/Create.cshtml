@model Dondurmacf.Model.Urun

@{
    ViewData["Title"] = "Ürün Ekle";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <h1 class="page-title mb-4">Yeni Ürün Ekle</h1>
        <div class="card card-custom p-4 border-0">
            <div class="card-body">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <div class="mb-3">
                        <label asp-for="UrunAdi" class="form-label font-weight-semibold">Ürün Adı</label>
                        <input asp-for="UrunAdi" class="form-control form-control-custom" placeholder="Ürün adını girin" required autocomplete="off" />
                        <span asp-validation-for="UrunAdi" class="text-danger small"></span>
                    </div>
                    <div class="mb-4">
                        <label asp-for="Aciklama" class="form-label font-weight-semibold">Açıklama</label>
                        <textarea asp-for="Aciklama" class="form-control form-control-custom" rows="3" placeholder="Ürün açıklaması girin" required></textarea>
                        <span asp-validation-for="Aciklama" class="text-danger small"></span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-secondary-custom">Geri Dön</a>
                        <button type="submit" class="btn btn-primary-custom">Kaydet</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
