@model IEnumerable<Dondurmacf.Model.Urun>

@{
    ViewData["Title"] = "Ürünler";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="page-title">Ürün Kategorileri</h1>
    <a asp-action="Create" class="btn btn-primary-custom">✨ Yeni Ürün Ekle</a>
</div>

<div class="card card-custom p-4 border-0">
    <div class="table-responsive">
        <table class="table table-custom">
            <thead>
                <tr>
                    <th>Ürün No</th>
                    <th>Ürün Adı</th>
                    <th>Açıklama</th>
                    <th class="text-end">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.UrunNo</td>
                        <td class="font-weight-semibold text-dark">@item.UrunAdi</td>
                        <td>@item.Aciklama</td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@item.UrunNo" class="btn btn-sm btn-secondary-custom me-2">Düzenle</a>
                            <a asp-action="Delete" asp-route-id="@item.UrunNo" class="btn btn-sm btn-danger rounded-pill px-3">Sil</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
