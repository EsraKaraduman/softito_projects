@{
    ViewData["Title"] = "Giriş Yap";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card card-custom p-4 shadow-lg border-0">
            <div class="card-body">
                <div class="text-center mb-4">
                    <h2 class="font-weight-bold text-dark">🍨 Hoş Geldiniz</h2>
                    <p class="text-muted">Lütfen giriş bilgilerinizi yazın</p>
                </div>

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger text-center rounded-3 py-2">
                        @ViewBag.Error
                    </div>
                }

                <form asp-action="Login" method="post">
                    <div class="mb-3">
                        <label class="form-label font-weight-semibold">Kullanıcı Adı</label>
                        <input type="text" name="username" class="form-control form-control-custom" placeholder="Kullanıcı adınızı girin" required autocomplete="off" />
                    </div>
                    <div class="mb-4">
                        <label class="form-label font-weight-semibold">Şifre</label>
                        <input type="password" name="password" class="form-control form-control-custom" placeholder="Şifrenizi girin" required />
                    </div>
                    <button type="submit" class="btn btn-primary-custom w-100 py-2 font-weight-bold">Giriş Yap</button>
                </form>

                <div class="text-center mt-4">
                    <p class="small text-muted mb-1">Varsayılan Bilgiler:</p>
                    <code class="d-block">Kullanıcı: admin / Şifre: 123</code>
                    <code class="d-block">Kullanıcı: user / Şifre: 123</code>
                </div>
            </div>
        </div>
    </div>
</div>
