@model TicketBooking.Core.Entities.Category
@{
    ViewData["Title"] = "Yeni Kategori Ekle";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card shadow-sm border-0 rounded-4 overflow-hidden bg-white">
                <div class="bg-primary text-white p-4">
                    <h3 class="fw-bold mb-0">Yeni Kategori Ekle</h3>
                    <p class="mb-0 opacity-75">Etkinlikleri gruplandırmak için yeni bir kategori oluşturun.</p>
                </div>
                
                <div class="card-body p-4">
                    <form asp-action="CreateCategory" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger alert alert-danger-custom" style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>

                        <div class="form-group mb-3">
                            <label asp-for="Name" class="form-label fw-semibold text-navy">Kategori Adı</label>
                            <input asp-for="Name" class="form-control" placeholder="Kategori adını girin" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="Description" class="form-label fw-semibold text-navy">Açıklama</label>
                            <textarea asp-for="Description" class="form-control" rows="3" placeholder="Kategori açıklamasını girin"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="form-check mb-4">
                            <input asp-for="IsActive" class="form-check-input" />
                            <label asp-for="IsActive" class="form-check-label fw-semibold text-navy">Aktif Kategori</label>
                        </div>

                        <div class="d-flex gap-3 justify-content-end border-top pt-4">
                            <a asp-action="Categories" class="btn btn-outline-secondary px-4">Geri Dön</a>
                            <button type="submit" class="btn btn-primary px-5 fw-semibold">Kategori Kaydet</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
