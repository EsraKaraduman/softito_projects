@model TicketBooking.Core.Entities.Event
@{
    ViewData["Title"] = "Etkinlik Düzenle";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 rounded-4 overflow-hidden bg-white">
                <div class="bg-primary text-white p-4">
                    <h3 class="fw-bold mb-0">Etkinlik Düzenle</h3>
                    <p class="mb-0 opacity-75">Etkinlik bilgilerini güncelleyin.</p>
                </div>
                
                <div class="card-body p-4">
                    <form asp-action="EditEvent" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger alert alert-danger-custom" style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="AvailableSeats" />

                        <div class="row">
                            <div class="col-md-6 form-group mb-3">
                                <label asp-for="Title" class="form-label fw-semibold text-navy">Etkinlik Başlığı</label>
                                <input asp-for="Title" class="form-control" placeholder="Etkinlik adını girin" />
                                <span asp-validation-for="Title" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 form-group mb-3">
                                <label asp-for="CategoryId" class="form-label fw-semibold text-navy">Kategori</label>
                                <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.Categories">
                                    <option value="">Seçiniz...</option>
                                </select>
                                <span asp-validation-for="CategoryId" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 form-group mb-3">
                                <label asp-for="Date" class="form-label fw-semibold text-navy">Tarih ve Saat</label>
                                <input asp-for="Date" class="form-control" type="datetime-local" />
                                <span asp-validation-for="Date" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 form-group mb-3">
                                <label asp-for="Location" class="form-label fw-semibold text-navy">Etkinlik Mekanı / Konum</label>
                                <input asp-for="Location" class="form-control" placeholder="Mekan bilgisini girin" />
                                <span asp-validation-for="Location" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 form-group mb-3">
                                <label asp-for="Price" class="form-label fw-semibold text-navy">Bilet Fiyatı (TL)</label>
                                <input asp-for="Price" class="form-control" type="number" step="0.01" min="0" placeholder="0.00" />
                                <span asp-validation-for="Price" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 form-group mb-3">
                                <label asp-for="Capacity" class="form-label fw-semibold text-navy">Kapasite (Koltuk Sayısı)</label>
                                <input asp-for="Capacity" class="form-control" type="number" min="1" placeholder="100" />
                                <span asp-validation-for="Capacity" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="ImageUrl" class="form-label fw-semibold text-navy">Görsel URL (İsteğe bağlı)</label>
                            <input asp-for="ImageUrl" class="form-control" placeholder="/images/etkinlik.jpg" />
                            <span asp-validation-for="ImageUrl" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-4">
                            <label asp-for="Description" class="form-label fw-semibold text-navy">Açıklama</label>
                            <textarea asp-for="Description" class="form-control" rows="4" placeholder="Etkinlik detaylarını girin"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="d-flex gap-3 justify-content-end border-top pt-4">
                            <a asp-action="Events" class="btn btn-outline-secondary px-4">İptal</a>
                            <button type="submit" class="btn btn-primary px-5 fw-semibold">Güncelle</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
