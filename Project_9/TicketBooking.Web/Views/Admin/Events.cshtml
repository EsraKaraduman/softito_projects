@model IEnumerable<TicketBooking.Core.Entities.Event>
@{
    ViewData["Title"] = "Etkinlikler";
}

<div class="container py-4">
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 pb-3 border-bottom">
        <div>
            <h2 class="fw-bold text-navy mb-1">Etkinlik Yönetimi</h2>
            <p class="text-muted mb-0">Etkinlikleri düzenleyin, yeni kayıt oluşturun veya iptal edin.</p>
        </div>
        <div class="mt-3 mt-sm-0">
            <a asp-action="CreateEvent" class="btn btn-primary fw-semibold px-4">
                Yeni Etkinlik Ekle
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm mb-4" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm mb-4" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card border-0 shadow-sm rounded-4 bg-white overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light fs-7">
                    <tr>
                        <th style="width: 80px;">ID</th>
                        <th>Etkinlik Adı</th>
                        <th>Kategori</th>
                        <th>Tarih</th>
                        <th>Mekan</th>
                        <th>Fiyat</th>
                        <th style="width: 150px;">Kapasite / Boş Koltuk</th>
                        <th style="width: 200px;" class="text-end">İşlemler</th>
                    </tr>
                </thead>
                <tbody class="fs-7">
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="8" class="text-center py-4 text-muted">Henüz etkinlik eklenmemiştir.</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var ev in Model)
                        {
                            <tr>
                                <td class="fw-semibold">#@ev.Id</td>
                                <td class="fw-bold text-navy">@ev.Title</td>
                                <td><span class="badge bg-light text-navy border">@ev.Category?.Name</span></td>
                                <td>@ev.Date.ToString("dd.MM.yyyy HH:mm")</td>
                                <td>@ev.Location</td>
                                <td class="fw-semibold text-primary">@ev.Price.ToString("C2")</td>
                                <td>
                                    <strong>@ev.AvailableSeats</strong> / @ev.Capacity
                                    <div class="progress mt-1" style="height: 6px; width: 100px;">
                                        @{
                                            var percent = ev.Capacity > 0 ? (100 - (ev.AvailableSeats * 100 / ev.Capacity)) : 0;
                                        }
                                        <div class="progress-bar" role="progressbar" style="width: @percent%;" aria-valuenow="@percent" aria-valuemin="0" aria-valuemax="100"></div>
                                    </div>
                                </td>
                                <td class="text-end">
                                    <div class="d-inline-flex gap-2">
                                        <a asp-action="EditEvent" asp-route-id="@ev.Id" class="btn btn-sm btn-outline-primary px-3">Düzenle</a>
                                        <form asp-action="DeleteEvent" asp-route-id="@ev.Id" method="post" onsubmit="return confirm('Bu etkinliği silmek istediğinizden emin misiniz?');">
                                            <button type="submit" class="btn btn-sm btn-outline-danger px-3">Sil</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
