@model IEnumerable<TicketBooking.Core.Entities.Category>
@{
    ViewData["Title"] = "Kategoriler";
}

<div class="container py-4">
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 pb-3 border-bottom">
        <div>
            <h2 class="fw-bold text-navy mb-1">Kategori Yönetimi</h2>
            <p class="text-muted mb-0">Etkinlik kategorilerini yönetin (Konser, Tiyatro vb.).</p>
        </div>
        <div class="mt-3 mt-sm-0">
            <a asp-action="CreateCategory" class="btn btn-primary fw-semibold px-4">
                Yeni Kategori Ekle
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm mb-4" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm mb-4" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card border-0 shadow-sm rounded-4 bg-white overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light fs-7">
                    <tr>
                        <th style="width: 80px;">ID</th>
                        <th>Kategori Adı</th>
                        <th>Açıklama</th>
                        <th style="width: 120px;">Durum</th>
                        <th style="width: 200px;" class="text-end">İşlemler</th>
                    </tr>
                </thead>
                <tbody class="fs-7">
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-4 text-muted">Henüz kategori eklenmemiştir.</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var cat in Model)
                        {
                            <tr>
                                <td class="fw-semibold">#@cat.Id</td>
                                <td class="fw-bold text-navy">@cat.Name</td>
                                <td>@cat.Description</td>
                                <td>
                                    @if (cat.IsActive)
                                    {
                                        <span class="badge bg-success-light text-success rounded-pill px-3 py-1">Aktif</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-light text-danger rounded-pill px-3 py-1">Pasif</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <div class="d-inline-flex gap-2">
                                        <a asp-action="EditCategory" asp-route-id="@cat.Id" class="btn btn-sm btn-outline-primary px-3">Düzenle</a>
                                        <form asp-action="DeleteCategory" asp-route-id="@cat.Id" method="post" onsubmit="return confirm('Bu kategoriyi silmek istediğinizden emin misiniz?');">
                                            <button type="submit" class="btn btn-sm btn-outline-danger px-3">Sil</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
