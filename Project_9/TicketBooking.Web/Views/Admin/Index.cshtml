@model IEnumerable<TicketBooking.Core.Entities.Ticket>
@{
    ViewData["Title"] = "Yönetim Paneli";
}

<div class="container py-4">
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 pb-3 border-bottom">
        <div>
            <h2 class="fw-bold text-navy mb-1">Yönetici Kontrol Paneli</h2>
            <p class="text-muted mb-0">Sistem istatistiklerini izleyin, etkinlikleri ve kategorileri yönetin.</p>
        </div>
        <div class="d-flex gap-2 mt-3 mt-sm-0">
            <a asp-controller="Ticket" asp-action="ExportToExcelAll" class="btn btn-success fw-semibold d-flex align-items-center">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-file-earmark-excel me-2" viewBox="0 0 16 16">
                    <path d="M5.884 6.68a.5.5 0 1 0-.768.64L7.349 10l-2.233 2.68a.5.5 0 0 0 .768.64L8 10.781l2.116 2.54a.5.5 0 0 0 .768-.641L8.651 10l2.233-2.68a.5.5 0 0 0-.768-.64L8 9.219l-2.116-2.54z"/>
                </svg>
                Tüm Satışları Excel'e Aktar
            </a>
        </div>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 bg-white p-3 text-center">
                <span class="fs-8 text-uppercase tracking-wider text-muted">Toplam Satış</span>
                <h2 class="fw-bold text-primary mt-2 mb-0">@(((decimal)ViewBag.TotalSales).ToString("C2"))</h2>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 bg-white p-3 text-center">
                <span class="fs-8 text-uppercase tracking-wider text-muted">Satılan Bilet</span>
                <h2 class="fw-bold text-navy mt-2 mb-0">@ViewBag.TotalTicketsSold Adet</h2>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 bg-white p-3 text-center">
                <span class="fs-8 text-uppercase tracking-wider text-muted">Aktif Etkinlikler</span>
                <h2 class="fw-bold text-navy mt-2 mb-0">@ViewBag.EventsCount</h2>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 bg-white p-3 text-center">
                <span class="fs-8 text-uppercase tracking-wider text-muted">Kategoriler</span>
                <h2 class="fw-bold text-navy mt-2 mb-0">@ViewBag.CategoriesCount</h2>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm rounded-4 bg-light-blue p-4 d-flex flex-row align-items-center justify-content-between">
                <div>
                    <h4 class="fw-bold text-navy mb-1">Etkinlik Yönetimi</h4>
                    <p class="text-muted mb-0">Yeni etkinlik ekleyin, bilgileri düzenleyin veya silin.</p>
                </div>
                <a asp-action="Events" class="btn btn-primary fw-semibold px-4 py-2">Yönet</a>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card border-0 shadow-sm rounded-4 bg-light-blue p-4 d-flex flex-row align-items-center justify-content-between">
                <div>
                    <h4 class="fw-bold text-navy mb-1">Kategori Yönetimi</h4>
                    <p class="text-muted mb-0">Etkinlik türlerini (Konser, Tiyatro vb.) tanımlayın.</p>
                </div>
                <a asp-action="Categories" class="btn btn-primary fw-semibold px-4 py-2">Yönet</a>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 bg-white overflow-hidden">
        <div class="p-4 border-bottom bg-light">
            <h5 class="fw-bold text-navy mb-0">Son Satış İşlemleri</h5>
        </div>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light fs-7">
                    <tr>
                        <th>Bilet ID</th>
                        <th>Kullanıcı</th>
                        <th>Etkinlik</th>
                        <th>Koltuk No</th>
                        <th>Adet</th>
                        <th>Tarih</th>
                        <th class="text-end">Tutar</th>
                    </tr>
                </thead>
                <tbody class="fs-7">
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center py-4 text-muted">Henüz satış işlemi gerçekleştirilmemiştir.</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var ticket in Model)
                        {
                            <tr>
                                <td class="fw-bold text-primary">#@ticket.Id</td>
                                <td>
                                    <strong>@ticket.User?.Username</strong><br />
                                    <span class="text-muted fs-8">@ticket.User?.Email</span>
                                </td>
                                <td>@ticket.Event?.Title</td>
                                <td><span class="badge bg-light text-navy border">@ticket.SeatNumber</span></td>
                                <td>@ticket.Quantity Adet</td>
                                <td>@ticket.BookingDate.ToString("dd.MM.yyyy HH:mm")</td>
                                <td class="text-end fw-semibold text-navy">@ticket.TotalPrice.ToString("C2")</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
