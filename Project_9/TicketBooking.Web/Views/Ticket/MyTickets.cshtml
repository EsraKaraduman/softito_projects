@model IEnumerable<TicketBooking.Core.Entities.Ticket>
@{
    ViewData["Title"] = "Biletlerim";
}

<div class="container py-4">
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 pb-3 border-bottom">
        <div>
            <h2 class="fw-bold text-navy mb-1">Satın Aldığım Biletler</h2>
            <p class="text-muted mb-0">Etkinlik biletlerinizi görüntüleyin, PDF faturalarını indirin veya yönetin.</p>
        </div>
        <div class="d-flex gap-2 mt-3 mt-sm-0">
            @if (Model.Any())
            {
                <a asp-action="ExportToExcel" class="btn btn-outline-success d-flex align-items-center fw-semibold px-3">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-file-earmark-excel me-2" viewBox="0 0 16 16">
                        <path d="M5.884 6.68a.5.5 0 1 0-.768.64L7.349 10l-2.233 2.68a.5.5 0 0 0 .768.64L8 10.781l2.116 2.54a.5.5 0 0 0 .768-.641L8.651 10l2.233-2.68a.5.5 0 0 0-.768-.64L8 9.219l-2.116-2.54z"/>
                        <path d="M14 14V4.5L9.5 0H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2zM9.5 3A1.5 1.5 0 0 0 11 4.5h2V14a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1h5.5v2z"/>
                    </svg>
                    Excel'e Aktar
                </a>
            }
            <a href="/" class="btn btn-primary d-flex align-items-center fw-semibold px-3">
                Yeni Bilet Al
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm mb-4" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm mb-4" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="text-center py-5 bg-white rounded-4 shadow-sm border">
            <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" fill="currentColor" class="text-muted opacity-50 mb-3" viewBox="0 0 16 16">
                <path d="M0 4.5A1.5 1.5 0 0 1 1.5 3h13A1.5 1.5 0 0 1 16 4.5V6a.5.5 0 0 1-.5.5 1.5 1.5 0 0 0 0 3 .5.5 0 0 1 .5.5v1.5a1.5 1.5 0 0 1-1.5 1.5h-13A1.5 1.5 0 0 1 0 11.5V10a.5.5 0 0 1 .5-.5 1.5 1.5 0 0 0 0-3A.5.5 0 0 1 0 6V4.5zM1.5 4a.5.5 0 0 0-.5.5v1.05a2.5 2.5 0 0 1 0 4.9v1.05a.5.5 0 0 0 .5.5h13a.5.5 0 0 0 .5-.5v-1.05a2.5 2.5 0 0 1 0-4.9V4.5a.5.5 0 0 0-.5-.5h-13z"/>
            </svg>
            <h4 class="fw-bold text-navy">Henüz biletiniz bulunmuyor</h4>
            <p class="text-muted">Güncel etkinlikleri inceleyerek bilet satın alabilirsiniz.</p>
            <a href="/" class="btn btn-primary px-4 py-2 mt-2">Etkinlikleri Keşfet</a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var ticket in Model)
            {
                <div class="col-lg-6">
                    <div class="card h-100 ticket-item-card shadow-sm border rounded-4 bg-white overflow-hidden">
                        <div class="row g-0 h-100">
                            <div class="col-sm-3 bg-navy-light d-flex flex-column align-items-center justify-content-center py-4 border-end-dashed">
                                <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" fill="currentColor" class="text-primary mb-2" viewBox="0 0 16 16">
                                    <path d="M0 4.5A1.5 1.5 0 0 1 1.5 3h13A1.5 1.5 0 0 1 16 4.5V6a.5.5 0 0 1-.5.5 1.5 1.5 0 0 0 0 3 .5.5 0 0 1 .5.5v1.5a1.5 1.5 0 0 1-1.5 1.5h-13A1.5 1.5 0 0 1 0 11.5V10a.5.5 0 0 1 .5-.5 1.5 1.5 0 0 0 0-3A.5.5 0 0 1 0 6V4.5z"/>
                                </svg>
                                <span class="fs-8 fw-semibold text-navy text-uppercase tracking-wider">BİLET NO</span>
                                <span class="fs-6 fw-bold text-primary">#@ticket.Id</span>
                            </div>

                            <div class="col-sm-9 p-4 d-flex flex-column">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <h5 class="fw-bold text-navy mb-0">@ticket.Event?.Title</h5>
                                </div>

                                <div class="mb-3 text-muted fs-7">
                                    <div class="d-flex align-items-center mb-1">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="bi bi-calendar-event me-2 text-primary" viewBox="0 0 16 16">
                                            <path d="M11 6.5a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-1a.5.5 0 0 1-.5-.5v-1z"/>
                                            <path d="M3.5 0a.5.5 0 0 1 .5.5V1h8V.5a.5.5 0 0 1 1 0V1h1a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V3a2 2 0 0 1 2-2h1V.5a.5.5 0 0 1 .5-.5zM1 4v10a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V4H1z"/>
                                        </svg>
                                        <span>@ticket.Event?.Date.ToString("dd.MM.yyyy, dddd HH:mm")</span>
                                    </div>
                                    <div class="d-flex align-items-center mb-1">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="bi bi-geo-alt me-2 text-primary" viewBox="0 0 16 16">
                                            <path d="M12.166 8.94c-.524 1.062-1.234 2.12-1.96 3.07A31.493 31.493 0 0 1 8 14.58a31.481 31.481 0 0 1-2.206-2.57c-.726-.95-1.436-2.008-1.96-3.07C3.304 7.867 3 6.862 3 6a5 5 0 0 1 10 0c0 .862-.305 1.867-.834 2.94zM8 16s6-5.686 6-10A6 6 0 0 0 2 6c0 4.314 6 10 6 10z"/>
                                        </svg>
                                        <span>@ticket.Event?.Location</span>
                                    </div>
                                    <div class="d-flex align-items-center">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="bi bi-layout-text-window-reversed me-2 text-primary" viewBox="0 0 16 16">
                                            <path d="M13 6.5a.5.5 0 0 0-.5-.5h-5a.5.5 0 0 0 0 1h5a.5.5 0 0 0 .5-.5zm0 3a.5.5 0 0 0-.5-.5h-5a.5.5 0 0 0 0 1h5a.5.5 0 0 0 .5-.5zm-.5 2.5a.5.5 0 0 1 0 1h-5a.5.5 0 0 1 0-1h5z"/>
                                        </svg>
                                        <span>Koltuk: <strong class="text-navy">@ticket.SeatNumber</strong>, Adet: <strong class="text-navy">@ticket.Quantity</strong></span>
                                    </div>
                                </div>

                                <div class="mt-auto pt-3 border-top d-flex justify-content-between align-items-center">
                                    <div>
                                        <span class="fs-8 text-muted d-block">Ödenen Tutar</span>
                                        <span class="fs-5 fw-bold text-navy">@ticket.TotalPrice.ToString("C2")</span>
                                    </div>
                                    <div class="d-flex gap-2">
                                        <a asp-action="Invoice" asp-route-id="@ticket.Id" class="btn btn-sm btn-outline-primary px-3 py-2 fw-semibold d-flex align-items-center">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="bi bi-file-pdf me-1" viewBox="0 0 16 16">
                                                <path d="M4 0a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2H4zm0 1h8a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1z"/>
                                            </svg>
                                            PDF / Yazdır
                                        </a>

                                        @if (ticket.Event != null && ticket.Event.Date > DateTime.Now.AddDays(1))
                                        {
                                            <form asp-action="Cancel" asp-route-id="@ticket.Id" method="post" onsubmit="return confirm('Bu bileti iptal etmek istediğinizden emin misiniz?');">
                                                <button type="submit" class="btn btn-sm btn-outline-danger px-3 py-2 fw-semibold">
                                                    İptal Et
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <span class="badge bg-light text-muted border d-flex align-items-center px-3" title="Son 24 saat kalan etkinliklerin biletleri iptal edilemez.">
                                                İptal Edilemez
                                            </span>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
