@model TicketBooking.Web.Models.BookTicketViewModel
@{
    ViewData["Title"] = "Bilet Satın Al";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 rounded-4 overflow-hidden bg-white">
                <div class="bg-primary text-white p-4">
                    <h3 class="fw-bold mb-0">Bilet Satın Al</h3>
                    <p class="mb-0 opacity-75">Seçtiğiniz etkinlik için koltuğunuzu ayırtın.</p>
                </div>
                
                <div class="card-body p-4">
                    <div class="row mb-4">
                        <div class="col-md-6 border-end">
                            <h5 class="fw-bold text-navy mb-3">Etkinlik Bilgileri</h5>
                            <h4 class="text-primary fw-semibold mb-2">@Model.EventTitle</h4>
                            <p class="text-muted mb-2">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-calendar2-event me-2" viewBox="0 0 16 16">
                                    <path d="M11 7.5a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-1a.5.5 0 0 1-.5-.5v-1z"/>
                                    <path d="M3.5 0a.5.5 0 0 1 .5.5V1h8V.5a.5.5 0 0 1 1 0V1h1a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V3a2 2 0 0 1 2-2h1V.5a.5.5 0 0 1 .5-.5zM2 2a1 1 0 0 0-1 1v11a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V3a1 1 0 0 0-1-1H2z"/>
                                    <path d="M2.5 4a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 .5.5V5H2.5V4z"/>
                                </svg>
                                @Model.EventDate.ToString("dd MMMM yyyy, dddd HH:mm")
                            </p>
                            <p class="text-muted">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-geo-alt me-2" viewBox="0 0 16 16">
                                    <path d="M12.166 8.94c-.524 1.062-1.234 2.12-1.96 3.07A31.493 31.493 0 0 1 8 14.58a31.481 31.481 0 0 1-2.206-2.57c-.726-.95-1.436-2.008-1.96-3.07C3.304 7.867 3 6.862 3 6a5 5 0 0 1 10 0c0 .862-.305 1.867-.834 2.94zM8 16s6-5.686 6-10A6 6 0 0 0 2 6c0 4.314 6 10 6 10z"/>
                                    <path d="M8 8a2 2 0 1 1 0-4 2 2 0 0 1 0 4zm0 1a3 3 0 1 0 0-6 3 3 0 0 0 0 6z"/>
                                </svg>
                                @Model.EventLocation
                            </p>
                        </div>
                        <div class="col-md-6 ps-md-4">
                            <h5 class="fw-bold text-navy mb-3">Fiyatlandırma</h5>
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted">Bilet Fiyatı:</span>
                                <span class="fw-semibold text-navy">@Model.Price.ToString("C2")</span>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted">Kalan Boş Koltuk:</span>
                                <span class="fw-semibold text-navy">@Model.AvailableSeats</span>
                            </div>
                            <hr />
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="fw-bold text-navy">Toplam Tutar:</span>
                                <span class="fs-3 fw-bold text-primary" id="totalPriceSpan">@Model.Price.ToString("C2")</span>
                            </div>
                        </div>
                    </div>

                    <form asp-action="Book" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger alert alert-danger-custom" style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>
                        <input type="hidden" asp-for="EventId" />

                        <div class="row">
                            <div class="col-md-6 form-group mb-3">
                                <label asp-for="Quantity" class="form-label fw-semibold text-navy"></label>
                                <input asp-for="Quantity" class="form-control" type="number" min="1" max="10" id="ticketQuantity" />
                                <span asp-validation-for="Quantity" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 form-group mb-4">
                                <label asp-for="SeatNumber" class="form-label fw-semibold text-navy"></label>
                                <input asp-for="SeatNumber" class="form-control" placeholder="Örn: B-14" />
                                <span asp-validation-for="SeatNumber" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="d-flex gap-3 justify-content-end border-top pt-4">
                            <a href="/" class="btn btn-outline-secondary px-4 py-2">İptal Et</a>
                            <button type="submit" class="btn btn-primary px-5 py-2 fw-semibold">Ödeme Yap ve Bilet Al</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            var quantityInput = document.getElementById("ticketQuantity");
            var totalPriceSpan = document.getElementById("totalPriceSpan");
            var unitPrice = @Html.Raw(Model.Price.ToString("F2", System.Globalization.CultureInfo.InvariantCulture));

            function updatePrice() {
                var qty = parseInt(quantityInput.value) || 1;
                if(qty < 1) qty = 1;
                if(qty > 10) qty = 10;
                var total = qty * unitPrice;
                totalPriceSpan.textContent = total.toLocaleString('tr-TR', { style: 'currency', currency: 'TRY' });
            }

            quantityInput.addEventListener("input", updatePrice);
            quantityInput.addEventListener("change", updatePrice);
        });
    </script>
}
