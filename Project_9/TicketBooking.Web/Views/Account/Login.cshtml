@model TicketBooking.Web.Models.LoginViewModel
@{
    ViewData["Title"] = "Giriş Yap";
}

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-header">
            <h2>BiletAl'a Hoş Geldiniz</h2>
            <p>Hesabınıza giriş yaparak biletlerinizi yönetin.</p>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">
                @TempData["SuccessMessage"]
            </div>
        }

        <form asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger alert alert-danger-custom" style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>

            <div class="form-group mb-3">
                <label asp-for="EmailOrUsername" class="form-label"></label>
                <input asp-for="EmailOrUsername" class="form-control" placeholder="Kullanıcı adı veya e-posta girin" />
                <span asp-validation-for="EmailOrUsername" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Password" class="form-label"></label>
                <input asp-for="Password" class="form-control" placeholder="Şifrenizi girin" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="form-check mb-4">
                <input asp-for="RememberMe" class="form-check-input" />
                <label asp-for="RememberMe" class="form-check-label"></label>
            </div>

            <button type="submit" class="btn btn-primary w-100 btn-auth">Giriş Yap</button>
        </form>

        <div class="auth-footer mt-4 text-center">
            <p>Hesabınız yok mu? <a asp-action="Register" class="auth-link">Hemen Kaydolun</a></p>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
