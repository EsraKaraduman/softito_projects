@{
    ViewData["Title"] = "Yetkisiz Erişim";
}

<div class="auth-container">
    <div class="auth-card text-center" style="max-width: 500px;">
        <div class="access-denied-icon mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" fill="currentColor" class="text-danger" viewBox="0 0 16 16">
                <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/>
                <path d="M7.002 11a1 1 0 1 1 2 0 1 1 0 0 1-2 0zM7.1 4.995a.905.905 0 1 1 1.8 0l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 4.995z"/>
            </svg>
        </div>
        <h2 class="text-dark fw-bold mb-3">Yetkisiz Erişim</h2>
        <p class="text-muted mb-4">Bu sayfayı görüntülemek için gerekli yetkiniz bulunmamaktadır. Lütfen yönetici hesabıyla giriş yapın veya anasayfaya dönün.</p>
        <div class="d-flex justify-content-center gap-3">
            <a href="/" class="btn btn-outline-primary px-4">Anasayfaya Dön</a>
            <a asp-controller="Account" asp-action="Login" class="btn btn-primary px-4">Giriş Yap</a>
        </div>
    </div>
</div>
