@model CikolataciMVC.Models.Kategoriler

@{
    Layout = "_Layout";
}

<h2>Kategori Düzenle</h2>

<form asp-action="Edit" method="post">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <input type="hidden" asp-for="Id" />

    <div class="form-group">
        <label>Kategori Adı</label>
        <input asp-for="KategoriAdi" class="form-control" />
        <span asp-validation-for="KategoriAdi" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary mt-2">Güncelle</button>
</form>
