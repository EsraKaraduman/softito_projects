@model IEnumerable<CikolataciMVC.Models.Kullanicilar>

@{
    Layout = "_Layout";
}

<h2>Kullanıcı Listesi</h2>

<p>
    <a class="btn btn-success" asp-action="Create">Yeni Kullanıcı</a>
</p>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Id</th>
            <th>Kullanıcı Adı</th>
            <th>Rol</th>
            <th>İşlemler</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var k in Model)
        {
            <tr>
                <td>@k.Id</td>
                <td>@k.KullaniciAdi</td>
                <td>@k.Rol</td>
                <td>
                    <a class="btn btn-warning btn-sm" asp-action="Edit" asp-route-id="@k.Id">Düzenle</a>
                    <a class="btn btn-danger btn-sm" asp-action="Delete" asp-route-id="@k.Id">Sil</a>
                </td>
            </tr>
        }
    </tbody>
</table>

