@model CikolataciMVC.Models.Kullanicilar

@{
    Layout = "_Layout";
}

<h2>Kullanıcı Düzenle</h2>

<form asp-action="Edit" method="post">
    @Html.AntiForgeryToken()

    <input type="hidden" asp-for="Id" />

    <div class="form-group">
        <label>Kullanıcı Adı</label>
        <input asp-for="KullaniciAdi" class="form-control" />
    </div>

    <div class="form-group">
        <label>Şifre</label>
        <input asp-for="Sifre" class="form-control" />
    </div>

    <div class="form-group">
        <label>Rol</label>
        <input asp-for="Rol" class="form-control" />
    </div>

    <button type="submit" class="btn btn-primary mt-2">Güncelle</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
