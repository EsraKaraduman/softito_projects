@model CikolataciMVC.Models.Urunler

@{
    Layout = "_Layout";
}

<h2>Ürün Düzenle</h2>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />

    <div class="form-group">
        <label>Ürün Adı</label>
        <input asp-for="UrunAdi" class="form-control" />
    </div>

    <div class="form-group">
        <label>Fiyat</label>
        <input asp-for="Fiyat" class="form-control" />
    </div>

    <div class="form-group">
        <label>Kategori</label>
        <select asp-for="KategoriId" class="form-select">
            @foreach (var k in ViewBag.Kategoriler)
            {
                <option value="@k.Id">@k.KategoriAdi</option>
            }
        </select>
    </div>

    <button class="btn btn-primary mt-2">Güncelle</button>
    <a class="btn btn-secondary mt-2" asp-action="Index">Geri</a>
</form>
