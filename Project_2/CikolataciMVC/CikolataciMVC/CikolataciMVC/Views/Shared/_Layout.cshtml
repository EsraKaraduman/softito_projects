<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>CikolataciMVC</title>

    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <a class="navbar-brand ms-3" asp-controller="Account" asp-action="Login">CikolataciMVC</a>

        <div class="collapse navbar-collapse">
            <ul class="navbar-nav ms-3">
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Admin" asp-action="Index">Admin Paneli</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="User" asp-action="Index">Kullanıcı Sayfası</a>
                </li>
            </ul>
        </div>

        <div class="me-3">
            <span class="text-light me-2">
                @Context.Session.GetString("KullaniciAdi")
            </span>
            <a class="btn btn-sm btn-outline-light" asp-controller="Account" asp-action="Logout">Çıkış</a>
        </div>
    </nav>

    <div class="container mt-4">
        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)
</body>
</html>
