@model CikolataciMVC.Models.Satislar

@{
    Layout = "_Layout";
}

<h2>Yeni Satış</h2>

<form asp-action="Create" method="post">
    <div class="form-group">
        <label>Ürün</label>
        <select asp-for="UrunId" class="form-select">
            @foreach (var u in ViewBag.Urunler)
            {
                <option value="@u.Id">@u.UrunAdi</option>
            }
        </select>
    </div>

    <div class="form-group">
        <label>Kullanıcı</label>
        <select asp-for="KullaniciId" class="form-select">
            @foreach (var k in ViewBag.Kullanicilar)
            {
                <option value="@k.Id">@k.KullaniciAdi</option>
            }
        </select>
    </div>

    <div class="form-group">
        <label>Adet</label>
        <input asp-for="Adet" class="form-control" />
    </div>

    <button class="btn btn-success mt-2">Kaydet</button>
    <a class="btn btn-secondary mt-2" asp-action="Index">Geri</a>
</form>
