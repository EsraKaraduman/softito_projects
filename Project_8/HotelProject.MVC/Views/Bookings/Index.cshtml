@model IEnumerable<HotelProject.MVC.Models.Booking>

@{
    ViewData["Title"] = "Rezervasyon Yönetimi";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="page-header m-0"><span class="text-gradient">Rezervasyonlar</span></h1>
    <div class="d-flex gap-2">
        <a asp-action="ExportExcel" class="btn btn-secondary">Excel'e Aktar</a>
        <a asp-action="PrintReport" target="_blank" class="btn btn-secondary">Rapor Yazdır / PDF</a>
        <a asp-action="Create" class="btn btn-primary">Yeni Rezervasyon</a>
    </div>
</div>

<div class="search-box">
    <form method="get" asp-action="Index" class="d-flex w-100 gap-3">
        <input type="text" name="query" class="form-control" placeholder="Misafir adı, e-posta veya oda ara..." value="@ViewBag.Query" />
        <button type="submit" class="btn btn-primary">Ara</button>
        @if (!string.IsNullOrEmpty(ViewBag.Query))
        {
            <a asp-action="Index" class="btn btn-secondary">Temizle</a>
        }
    </form>
</div>

<div class="table-responsive">
    <table class="table table-hover">
        <thead>
            <tr>
                <th>ID</th>
                <th>Misafir Adı</th>
                <th>E-posta</th>
                <th>Telefon</th>
                <th>Oda No</th>
                <th>Oda Tipi</th>
                <th>Giriş Tarihi</th>
                <th>Çıkış Tarihi</th>
                <th>Toplam Tutar</th>
                <th>Durum</th>
                <th>İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="11" class="text-center text-secondary py-4">Rezervasyon bulunamadı.</td>
                </tr>
            }
            else
            {
                foreach (var booking in Model)
                {
                    <tr>
                        <td>@booking.Id</td>
                        <td class="fw-semibold text-light">@booking.GuestName</td>
                        <td>@booking.GuestEmail</td>
                        <td>@booking.GuestPhone</td>
                        <td><span class="badge bg-secondary">Oda @booking.RoomNumber</span></td>
                        <td>@booking.RoomType</td>
                        <td>@booking.CheckInDate.ToString("dd.MM.yyyy")</td>
                        <td>@booking.CheckOutDate.ToString("dd.MM.yyyy")</td>
                        <td class="text-gradient fw-bold">@booking.TotalPrice.ToString("C")</td>
                        <td>
                            @if (booking.BookingStatus == "Confirmed")
                            {
                                <span class="badge badge-success">Onaylandı</span>
                            }
                            else
                            {
                                <span class="badge badge-danger">İptal Edildi</span>
                            }
                        </td>
                        <td>
                            <div class="d-flex gap-2">
                                <a asp-action="Edit" asp-route-id="@booking.Id" class="btn btn-secondary btn-sm">Düzenle</a>
                                <form method="post" asp-action="Delete" asp-route-id="@booking.Id" onsubmit="return confirm('Bu rezervasyonu silmek istediğinizden emin misiniz?');">
                                    <button type="submit" class="btn btn-danger btn-sm">Sil</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
