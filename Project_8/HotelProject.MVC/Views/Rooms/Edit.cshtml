@model HotelProject.MVC.Models.Room

@{
    ViewData["Title"] = "Odayı Düzenle";
}

<div class="form-container" style="max-width: 600px;">
    <h2 class="mb-4 text-center"><span class="text-gradient">Odayı Düzenle</span></h2>
    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger">@ViewBag.Error</div>
    }
    <form method="post" asp-action="Edit" asp-route-id="@Model.Id">
        <input type="hidden" asp-for="Id" />
        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Oda Numarası</label>
                <input type="text" asp-for="RoomNumber" class="form-control" required />
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">Oda Tipi</label>
                <select asp-for="RoomType" class="form-select" required>
                    <option value="Standart Oda">Standart Oda</option>
                    <option value="Deluxe Oda">Deluxe Oda</option>
                    <option value="Kral Dairesi (Suite)">Kral Dairesi (Suite)</option>
                    <option value="Aile Odası">Aile Odası</option>
                </select>
            </div>
        </div>
        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Gecelik Ücret (TL)</label>
                <input type="number" step="0.01" asp-for="PricePerNight" class="form-control" required />
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">Durum</label>
                <select asp-for="IsAvailable" class="form-select" required>
                    <option value="true">Müsait</option>
                    <option value="false">Dolu</option>
                </select>
            </div>
        </div>
        <div class="mb-3">
            <label class="form-label">Görsel URL</label>
            <input type="text" asp-for="ImageUrl" class="form-control" />
        </div>
        <div class="mb-4">
            <label class="form-label">Açıklama</label>
            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
        </div>
        <div class="d-flex gap-3">
            <button type="submit" class="btn btn-primary flex-grow-1">Güncelle</button>
            <a asp-action="Index" class="btn btn-secondary flex-grow-1 text-center">İptal</a>
        </div>
    </form>
</div>
