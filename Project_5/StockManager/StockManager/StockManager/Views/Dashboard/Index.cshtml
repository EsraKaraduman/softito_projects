@{
    ViewData["Title"] = "Dashboard";
    ViewData["ActivePage"] = "Dashboard";
}

<div class="row mb-4">
    <div class="col-12">
        <h2 class="text-white fw-bold mb-1">
            <i class="fa-solid fa-gauge-high text-primary me-2"></i>Dashboard
        </h2>
        <p class="text-muted small">Sistem özeti ve genel istatistik raporları.</p>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-4 col-lg-2.4 col-sm-6">
        <div class="card-premium p-4 h-100 d-flex flex-column justify-content-between">
            <div>
                <span class="text-muted small d-block mb-1">Toplam Ürün Çeşidi</span>
                <h2 class="text-white fw-bold mb-0">@ViewBag.TotalProducts</h2>
            </div>
            <div class="text-primary mt-3 align-self-end">
                <i class="fa-solid fa-boxes-packing fa-2x"></i>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-lg-2.4 col-sm-6">
        <div class="card-premium p-4 h-100 d-flex flex-column justify-content-between">
            <div>
                <span class="text-muted small d-block mb-1">Toplam Stok Miktarı</span>
                <h2 class="text-white fw-bold mb-0">@ViewBag.TotalStock adet</h2>
            </div>
            <div class="text-success mt-3 align-self-end">
                <i class="fa-solid fa-cubes fa-2x"></i>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-lg-2.4 col-sm-6">
        <div class="card-premium p-4 h-100 d-flex flex-column justify-content-between">
            <div>
                <span class="text-muted small d-block mb-1">Kritik Stok Uyarıları</span>
                <h2 class="text-white fw-bold mb-0">
                    @ViewBag.LowStockCount
                </h2>
            </div>
            <div class="text-danger mt-3 align-self-end">
                <i class="fa-solid fa-triangle-exclamation fa-2x"></i>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-lg-2.4 col-sm-6">
        <div class="card-premium p-4 h-100 d-flex flex-column justify-content-between">
            <div>
                <span class="text-muted small d-block mb-1">Tedarikçi Firmalar</span>
                <h2 class="text-white fw-bold mb-0">@ViewBag.TotalSuppliers</h2>
            </div>
            <div class="text-info mt-3 align-self-end">
                <i class="fa-solid fa-truck-ramp-box fa-2x"></i>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-lg-2.4 col-sm-6">
        <div class="card-premium p-4 h-100 d-flex flex-column justify-content-between">
            <div>
                <span class="text-muted small d-block mb-1">Toplam Depo Kapasitesi</span>
                <h2 class="text-white fw-bold mb-0">@ViewBag.TotalWarehouseCapacity m³</h2>
            </div>
            <div class="text-warning mt-3 align-self-end">
                <i class="fa-solid fa-warehouse fa-2x"></i>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-lg-7">
        <div class="card-premium p-4 h-100">
            <h5 class="text-white fw-bold mb-4"><i class="fa-solid fa-chart-simple text-primary me-2"></i>Depo Kapasite Dağılımları</h5>
            <div style="position: relative; height: 300px;">
                <canvas id="warehouseChart"></canvas>
            </div>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="card-premium p-4 h-100">
            <h5 class="text-white fw-bold mb-4"><i class="fa-solid fa-chart-pie text-primary me-2"></i>Kategori Bazlı Stok Dağılımı</h5>
            <div style="position: relative; height: 300px;">
                <canvas id="categoryChart"></canvas>
            </div>
        </div>
    </div>
</div>

<div class="row mb-4">
    <div class="col-12">
        <div class="card-premium p-4">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="text-white fw-bold mb-0">
                    <i class="fa-solid fa-triangle-exclamation text-danger me-2"></i>Kritik Seviyedeki Ürünler (< 15 adet)
                </h5>
                <a href="/Product" class="btn btn-outline-primary btn-sm rounded-pill px-3">
                    <i class="fa-solid fa-boxes-packing me-1"></i>Tüm Ürünleri Yönet
                </a>
            </div>
            <div class="table-responsive">
                <table class="table table-dark table-hover mb-0 align-middle">
                    <thead>
                        <tr class="text-muted small uppercase">
                            <th>Ürün Adı</th>
                            <th>Barkod / SKU</th>
                            <th>Kategori</th>
                            <th>Birim Fiyat</th>
                            <th>Mevcut Stok</th>
                            <th>Durum</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (ViewBag.LowStockProducts.Count == 0)
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted py-4">Kritik stok seviyesinde ürün bulunmamaktadır. 🎉</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var p in ViewBag.LowStockProducts)
                            {
                                <tr>
                                    <td class="text-white fw-semibold">@p.Name</td>
                                    <td><code class="text-info bg-dark bg-opacity-25 px-2 py-1 rounded">@p.Sku</code></td>
                                    <td>@p.Category</td>
                                    <td>$@p.UnitPrice.ToString("F2")</td>
                                    <td>
                                        <span class="fw-bold @(p.Quantity < 5 ? "text-danger" : "text-warning")">@p.Quantity adet</span>
                                    </td>
                                    <td>
                                        <span class="stats-pill @(p.Quantity < 5 ? "stats-pill-danger" : "stats-pill-warning")">
                                            @(p.Quantity < 5 ? "TÜKENDİ / KRİTİK" : "DÜŞÜK STOK")
                                        </span>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            var ctxCat = document.getElementById('categoryChart').getContext('2d');
            var catLabels = @Html.Raw(Json.Serialize(ViewBag.CategoryLabels));
            var catStocks = @Html.Raw(Json.Serialize(ViewBag.CategoryStocks));

            if (catLabels && catLabels.length > 0) {
                new Chart(ctxCat, {
                    type: 'doughnut',
                    data: {
                        labels: catLabels,
                        datasets: [{
                            data: catStocks,
                            backgroundColor: [
                                '#6366f1', '#10b981', '#f59e0b', '#06b6d4', '#ec4899', '#8b5cf6'
                            ],
                            borderWidth: 1,
                            borderColor: '#1e293b'
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                position: 'bottom',
                                labels: { color: '#94a3b8', font: { family: 'Inter', size: 11 } }
                            }
                        }
                    }
                });
            } else {
                ctxCat.canvas.parentNode.innerHTML = "<div class='text-center text-muted py-5'>Veri bulunamadı.</div>";
            }

            var ctxWh = document.getElementById('warehouseChart').getContext('2d');
            var whLabels = @Html.Raw(Json.Serialize(ViewBag.WarehouseLabels));
            var whCapacities = @Html.Raw(Json.Serialize(ViewBag.WarehouseCapacities));

            if (whLabels && whLabels.length > 0) {
                new Chart(ctxWh, {
                    type: 'bar',
                    data: {
                        labels: whLabels,
                        datasets: [{
                            label: 'Kapasite (m³)',
                            data: whCapacities,
                            backgroundColor: 'rgba(99, 102, 241, 0.65)',
                            borderColor: '#6366f1',
                            borderWidth: 1,
                            borderRadius: 6
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        scales: {
                            y: {
                                grid: { color: '#334155' },
                                ticks: { color: '#94a3b8' }
                            },
                            x: {
                                grid: { display: false },
                                ticks: { color: '#94a3b8' }
                            }
                        },
                        plugins: {
                            legend: { display: false }
                        }
                    }
                });
            } else {
                ctxWh.canvas.parentNode.innerHTML = "<div class='text-center text-muted py-5'>Veri bulunamadı.</div>";
            }
        });
    </script>
}
