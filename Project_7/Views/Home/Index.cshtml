@model IEnumerable<Project_7.Models.Course>

@{
    ViewData["Title"] = "Sanat Kurslarımız";
    var categories = new[] { "Painting", "Guitar", "Music", "Wood Painting" };
    var activeCategory = ViewBag.SelectedCategory as string;
    var searchQuery = ViewBag.SearchQuery as string;
}

<div class="hero-section">
    <h1 class="hero-title">Ruhunu Sanatla Besle</h1>
    <p class="hero-subtitle">Resim, müzik, gitar ve ahşap boyama gibi alanlarda uzman eğitmenler eşliğinde hayal gücünü gerçeğe dönüştür.</p>
</div>

<div class="container mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <form asp-controller="Home" asp-action="Index" method="get" class="d-flex mb-4">
                <input type="hidden" name="category" value="@activeCategory" />
                <input type="text" name="searchQuery" value="@searchQuery" class="form-control search-input me-2" placeholder="Kurs veya kategori ara..." aria-label="Search" />
                <button class="btn btn-custom-primary px-4" type="submit">Ara</button>
            </form>
        </div>
    </div>

    <div class="row justify-content-center mb-5">
        <div class="col-12 text-center">
            <a href="@Url.Action("Index", "Home", new { searchQuery = searchQuery })" class="filter-btn @(string.IsNullOrEmpty(activeCategory) ? "active" : "")">Tümü</a>
            @foreach (var cat in categories)
            {
                var turkishName = cat switch
                {
                    "Painting" => "Resim",
                    "Guitar" => "Gitar",
                    "Music" => "Müzik",
                    "Wood Painting" => "Ahşap Boyama",
                    _ => cat
                };
                <a href="@Url.Action("Index", "Home", new { category = cat, searchQuery = searchQuery })" class="filter-btn @(activeCategory == cat ? "active" : "")">@turkishName</a>
            }
        </div>
    </div>
</div>

<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
    @if (!Model.Any())
    {
        <div class="col-12 text-center my-5">
            <h3 class="text-muted">Aradığınız kriterlere uygun kurs bulunamadı.</h3>
        </div>
    }
    else
    {
        @foreach (var course in Model)
        {
            <div class="col">
                <div class="glass-card">
                    <img src="@course.ImageUrl" alt="@course.Title" class="card-img-custom" onerror="this.src='https://images.unsplash.com/photo-1513364776144-60967b0f800f?w=600'" />
                    <div>
                        <span class="category-badge">
                            @(course.Category switch
                            {
                                "Painting" => "Resim",
                                "Guitar" => "Gitar",
                                "Music" => "Müzik",
                                "Wood Painting" => "Ahşap Boyama",
                                _ => course.Category
                            })
                        </span>
                        <h3 class="card-title-custom">@course.Title</h3>
                        <p class="card-desc-custom">
                            @(course.Description.Length > 100 ? course.Description.Substring(0, 97) + "..." : course.Description)
                        </p>
                        <div class="d-flex justify-content-between align-items-center mt-3">
                            <span class="card-price-custom">@course.Price.ToString("C2")</span>
                            <span class="text-muted small">⏱ @course.Duration</span>
                        </div>
                    </div>
                    <div class="mt-4 pt-3 border-top border-secondary d-flex justify-content-between align-items-center">
                        <span class="small text-light">Eğitmen: <strong>@(course.Instructor?.FullName ?? "Belirtilmemiş")</strong></span>
                        <a asp-controller="Home" asp-action="Details" asp-route-id="@course.Id" class="btn btn-custom-secondary btn-sm">İncele</a>
                    </div>
                </div>
            </div>
        }
    }
</div>
