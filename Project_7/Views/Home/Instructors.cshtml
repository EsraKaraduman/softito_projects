@model IEnumerable<Project_7.Models.Instructor>

@{
    ViewData["Title"] = "Eğitmenlerimiz";
}

<div class="hero-section">
    <h1 class="hero-title">Uzman Eğitmen Kadromuz</h1>
    <p class="hero-subtitle">Alanında uzman, konservatuvar ve güzel sanatlar mezunu eğitmenlerimizle tanışın.</p>
</div>

<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
    @if (!Model.Any())
    {
        <div class="col-12 text-center my-5">
            <h3 class="text-muted">Eğitmen bilgisi bulunmamaktadır.</h3>
        </div>
    }
    else
    {
        @foreach (var inst in Model)
        {
            <div class="col">
                <div class="glass-card text-center d-flex flex-column align-items-center">
                    <img src="@inst.ImageUrl" alt="@inst.FullName" class="rounded-circle border border-primary border-3 mb-4" style="width: 150px; height: 150px; object-fit: cover;" onerror="this.src='https://images.unsplash.com/photo-1534528741775-53994a69daeb?w=300'" />
                    <h3 class="card-title-custom">@inst.FullName</h3>
                    <span class="category-badge mb-3">
                        @(inst.Specialty switch
                        {
                            "Painting" => "Resim Sanatı",
                            "Guitar" => "Gitar",
                            "Music" => "Müzik",
                            "Wood Painting" => "Ahşap Boyama",
                            _ => inst.Specialty
                        })
                    </span>
                    <p class="card-desc-custom text-center">@inst.Bio</p>
                </div>
            </div>
        }
    }
</div>
