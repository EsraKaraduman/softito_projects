@model IEnumerable<Project_7.Models.Instructor>

@{
    ViewData["Title"] = "Eğitmen Yönetimi";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="hero-title text-start fs-2 mb-0">Eğitmen Yönetimi</h2>
    <a asp-action="Create" class="btn btn-custom-primary">Yeni Eğitmen Ekle</a>
</div>

<div class="glass-card">
    <div class="table-responsive">
        <table class="custom-table">
            <thead>
                <tr>
                    <th>Görsel</th>
                    <th>Ad Soyad</th>
                    <th>Uzmanlık Alanı</th>
                    <th>Biyografi</th>
                    <th>İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <img src="@item.ImageUrl" alt="@item.FullName" class="rounded-circle" style="width: 50px; height: 50px; object-fit: cover;" onerror="this.src='https://images.unsplash.com/photo-1534528741775-53994a69daeb?w=100'" />
                        </td>
                        <td class="fw-bold">@item.FullName</td>
                        <td>
                            @(item.Specialty switch
                            {
                                "Painting" => "Resim",
                                "Guitar" => "Gitar",
                                "Music" => "Müzik",
                                "Wood Painting" => "Ahşap Boyama",
                                _ => item.Specialty
                            })
                        </td>
                        <td>@(item.Bio?.Length > 80 ? item.Bio.Substring(0, 77) + "..." : item.Bio)</td>
                        <td>
                            <div class="d-flex gap-2">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-custom-secondary">Düzenle</a>
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Bu eğitmeni silmek istediğinize emin misiniz?');">
                                    <button type="submit" class="btn btn-sm btn-custom-danger">Sil</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
