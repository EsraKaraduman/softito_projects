@model IEnumerable<Project_7.Models.Course>

@{
    ViewData["Title"] = "Kurs Yönetimi";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="hero-title text-start fs-2 mb-0">Kurs Yönetimi</h2>
    <a asp-action="Create" class="btn btn-custom-primary">Yeni Kurs Ekle</a>
</div>

<div class="glass-card">
    <div class="table-responsive">
        <table class="custom-table">
            <thead>
                <tr>
                    <th>Görsel</th>
                    <th>Kurs Başlığı</th>
                    <th>Kategori</th>
                    <th>Fiyat</th>
                    <th>Süre</th>
                    <th>Eğitmen</th>
                    <th>İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <img src="@item.ImageUrl" alt="@item.Title" class="rounded" style="width: 60px; height: 40px; object-fit: cover;" onerror="this.src='https://images.unsplash.com/photo-1513364776144-60967b0f800f?w=600'" />
                        </td>
                        <td class="fw-bold">@item.Title</td>
                        <td>
                            @(item.Category switch
                            {
                                "Painting" => "Resim",
                                "Guitar" => "Gitar",
                                "Music" => "Müzik",
                                "Wood Painting" => "Ahşap Boyama",
                                _ => item.Category
                            })
                        </td>
                        <td class="text-warning">@item.Price.ToString("C2")</td>
                        <td>@item.Duration</td>
                        <td>@(item.Instructor?.FullName ?? "-")</td>
                        <td>
                            <div class="d-flex gap-2">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-custom-secondary">Düzenle</a>
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Bu kursu silmek istediğinize emin misiniz?');">
                                    <button type="submit" class="btn btn-sm btn-custom-danger">Sil</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
