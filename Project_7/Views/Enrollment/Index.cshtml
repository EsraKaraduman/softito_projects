@model IEnumerable<Project_7.Models.EnrollmentDetailViewModel>

@{
    ViewData["Title"] = "Tüm Kayıtlar Raporu";
}

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
    <div>
        <h2 class="hero-title text-start fs-2 mb-1">Tüm Kayıtlar Raporu</h2>
        <p class="text-muted mb-0">Öğrencilerin kurs kayıtlarını inceleyin ve dışa aktarın.</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-controller="Export" asp-action="ExportToExcel" class="btn btn-custom-secondary border-success text-success">
            📊 Excel Raporu İndir
        </a>
        <a asp-controller="Export" asp-action="PdfReport" target="_blank" class="btn btn-custom-primary">
            🖨️ PDF Raporu Al
        </a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success bg-dark bg-opacity-50 text-success border-success mb-4">
        @TempData["SuccessMessage"]
    </div>
}

<div class="glass-card">
    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <h4 class="text-muted">Henüz kayıtlı bir öğrenci bulunmamaktadır.</h4>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="custom-table">
                <thead>
                    <tr>
                        <th>Kayıt ID</th>
                        <th>Öğrenci Adı</th>
                        <th>E-posta</th>
                        <th>Kurs Adı</th>
                        <th>Kategori</th>
                        <th>Ücret</th>
                        <th>Kayıt Tarihi</th>
                        <th>Durum</th>
                        <th>İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold">#@item.EnrollmentId</td>
                            <td class="text-white">@item.UserFullName</td>
                            <td>@item.UserEmail</td>
                            <td class="text-white">@item.CourseTitle</td>
                            <td>
                                @(item.Category switch
                                {
                                    "Painting" => "Resim",
                                    "Guitar" => "Gitar",
                                    "Music" => "Müzik",
                                    "Wood Painting" => "Ahşap Boyama",
                                    _ => item.Category
                                })
                            </td>
                            <td class="text-warning">@item.CoursePrice.ToString("C2")</td>
                            <td>@item.EnrollmentDate.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>
                                @if (item.Status == "Active")
                                {
                                    <span class="badge-active">Aktif</span>
                                }
                                else
                                {
                                    <span class="badge-cancelled">İptal Edildi</span>
                                }
                            </td>
                            <td>
                                @if (item.Status == "Active")
                                {
                                    <form asp-action="Cancel" asp-route-id="@item.EnrollmentId" asp-route-returnUrl="@Context.Request.Path" method="post" onsubmit="return confirm('Bu öğrencinin kaydını iptal etmek istediğinize emin misiniz?');">
                                        <button type="submit" class="btn btn-sm btn-custom-danger">Kayıt İptal</button>
                                    </form>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
