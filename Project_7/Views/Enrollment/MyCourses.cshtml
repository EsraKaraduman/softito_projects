@model IEnumerable<Project_7.Models.EnrollmentDetailViewModel>

@{
    ViewData["Title"] = "Katıldığım Kurslar";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="hero-title text-start fs-2 mb-0">Katıldığım Kurslar</h2>
    <a asp-controller="Home" asp-action="Index" class="btn btn-custom-primary">Yeni Kurs Keşfet</a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success bg-dark bg-opacity-50 text-success border-success mb-4">
        @TempData["SuccessMessage"]
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger bg-dark bg-opacity-50 text-danger border-danger mb-4">
        @TempData["ErrorMessage"]
    </div>
}

<div class="glass-card">
    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <h4 class="text-muted mb-3">Henüz kayıtlı bir kursunuz bulunmamaktadır.</h4>
            <p class="text-light">Sanat kurslarımıza göz atmak ister misiniz?</p>
            <a asp-controller="Home" asp-action="Index" class="btn btn-custom-secondary mt-2">Kursları Listele</a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="custom-table">
                <thead>
                    <tr>
                        <th>Kurs Adı</th>
                        <th>Kategori</th>
                        <th>Fiyat</th>
                        <th>Kayıt Tarihi</th>
                        <th>Durum</th>
                        <th>İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold text-white">@item.CourseTitle</td>
                            <td>
                                @(item.Category switch
                                {
                                    "Painting" => "Resim",
                                    "Guitar" => "Gitar",
                                    "Music" => "Müzik",
                                    "Wood Painting" => "Ahşap Boyama",
                                    _ => item.Category
                                })
                            </td>
                            <td class="text-warning">@item.CoursePrice.ToString("C2")</td>
                            <td>@item.EnrollmentDate.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>
                                @if (item.Status == "Active")
                                {
                                    <span class="badge-active">Aktif</span>
                                }
                                else
                                {
                                    <span class="badge-cancelled">İptal Edildi</span>
                                }
                            </td>
                            <td>
                                @if (item.Status == "Active")
                                {
                                    <form asp-action="Cancel" asp-route-id="@item.EnrollmentId" method="post" onsubmit="return confirm('Bu kurs kaydını iptal etmek istediğinize emin misiniz?');">
                                        <button type="submit" class="btn btn-sm btn-custom-danger">Kayıt İptal</button>
                                    </form>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
